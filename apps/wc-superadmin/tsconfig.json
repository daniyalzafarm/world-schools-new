{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@world-schools/ui-web": ["../../packages/ui-web/src/index.ts"],
      "@world-schools/wc-types": ["../../packages/wc-types/src/index.ts"],
      "@world-schools/wc-utils": ["../../packages/wc-utils/src/index.ts"],
      "@world-schools/wc-frontend-utils": ["../../packages/wc-frontend-utils/src/index.ts"],
      "@world-schools/wc-frontend-utils/runtime-config": [
        "../../packages/wc-frontend-utils/src/lib/runtime-config/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "../../apps/wc-superadmin/.next/types/**/*.ts",
    "../../dist/apps/wc-superadmin/.next/types/**/*.ts",
    "next-env.d.ts"
  ],
  "exclude": ["node_modules", "jest.config.ts", "**/*.spec.ts", "**/*.test.ts"]
}

# Runtime config (read at request time on the server, injected to
# window.__APP_CONFIG__ via the root layout's inline <script>).
# No NEXT_PUBLIC_* prefix — env vars are NOT baked into the build.

# App URL (used as metadataBase for SEO / OpenGraph)
APP_URL=http://localhost:4301

# API Configuration
# Base URL for the wc-nest-api backend (superadmin module)
API_BASE_URL=http://localhost:3000/

# WebSocket Configuration
# WebSocket server URL for real-time messaging (gateway runs on the API's HTTP port)
WS_URL=http://localhost:3000

# Cross-app Navigation
# Base URL for the wc-provider app
PROVIDER_APP_URL=http://localhost:4302
# Base URL for the wc-booking app
BOOKING_APP_URL=http://localhost:4303

# Authentication Configuration
# Set to 'true' to use request-based auth (tokens in headers)
# Set to 'false' to use cookie-based auth (HTTP-only cookies) - recommended for production
AUTH_USING_REQUEST=false

# App Version (automatically set during CI/CD deployment)
APP_VERSION=dev

{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.nextjs.json",
  "compilerOptions": {
    // App-specific path aliases
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@world-schools/ui-web": ["../../packages/ui-web/src/index.ts"],
      "@world-schools/schoolable-utils": [
        "../../packages/schoolable-utils/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "../../apps/schoolable-web/.next/types/**/*.ts",
    "../../dist/apps/schoolable-web/.next/types/**/*.ts",
    "next-env.d.ts"
  ],
  "exclude": ["node_modules", "jest.config.ts", "**/*.spec.ts", "**/*.test.ts"]
}

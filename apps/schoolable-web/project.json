{
  "name": "schoolable-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/schoolable-web",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project schoolable-web --web",
  "targets": {
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
        "cwd": "apps/schoolable-web"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
        "cwd": "apps/schoolable-web"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx lint schoolable-web --fix", "nx format schoolable-web"],
        "parallel": false
      }
    }
  }
}

{
  "name": "schoolable-nest-api-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["schoolable-nest-api"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/schoolable-nest-api-e2e/jest.config.ts",
        "passWithNoTests": true
      },
      "dependsOn": ["schoolable-nest-api:build", "schoolable-nest-api:serve"]
    }
  }
}

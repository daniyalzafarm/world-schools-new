# DEV
PORT=0000

# API Configuration
# Base URL for the wc-nest-api backend (provider module)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/

# WebSocket Configuration
# WebSocket server URL for real-time messaging
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Booking App Configuration
# Base URL for the wc-booking app (for cross-app navigation)
NEXT_PUBLIC_BOOKING_APP_BASE_URL=http://localhost:4303

# Authentication Configuration
# Set to 'true' to use request-based auth (tokens in headers)
# Set to 'false' to use cookie-based auth (HTTP-only cookies) - recommended for production
NEXT_PUBLIC_AUTH_USING_REQUEST=false

# App Version (automatically set during CI/CD deployment)
NEXT_PUBLIC_APP_VERSION=dev

# Google Maps API Configuration
# API key for Google Maps JavaScript API and Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# WebSocket Feature Flags
# Enable WebSocket-based message sending (default: true, set to false to use HTTP)
# Note: Real-time receiving (incoming messages, typing, presence) always works via WebSocket
NEXT_PUBLIC_ENABLE_WEBSOCKET_MESSAGES=true
# Enable HTTP fallback when WebSocket is unavailable (default: true)
NEXT_PUBLIC_WEBSOCKET_FALLBACK_HTTP=true

# Custom Environment Variables
PROVIDER_CUSTOM_KEY=your-custom-key-here

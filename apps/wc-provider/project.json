{
  "name": "wc-provider",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/wc-provider",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project wc-provider --web",
  "targets": {
    "dev": {
      "options": {
        "port": 4302
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
        "cwd": "apps/wc-provider"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
        "cwd": "apps/wc-provider"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx lint wc-provider --fix", "nx format wc-provider"],
        "parallel": false
      }
    }
  }
}

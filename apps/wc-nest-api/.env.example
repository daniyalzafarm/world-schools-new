# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wc-booking-system
POSTGRES_REQUIRE_SSL=false
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS="10"

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN="http://localhost:3000,http://localhost:4200"

# Security
HELMET_ENABLED=true
TRUST_PROXY=false

# Email Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="noreply@worldschools.com"

# Frontend Portal URLs
SUPERADMIN_PORTAL_URL="http://localhost:4301"
PROVIDER_PORTAL_URL="http://localhost:4302"
BOOKING_PORTAL_URL="http://localhost:4303"

# File Upload Configuration
MAX_FILE_SIZE="10485760"
UPLOAD_DEST="./uploads"

# Azure Storage Configuration
# Azure Storage account name (e.g., "wcstorageaccount")
AZURE_STORAGE_ACCOUNT_NAME=""
# Azure Storage account key (found in Azure Portal > Storage Account > Access Keys)
AZURE_STORAGE_ACCOUNT_KEY=""
# Container name for provider verification documents (e.g., "wc-staging-files")
AZURE_STORAGE_CONTAINER_NAME=""
# SAS token expiry duration in hours (default: 24 hours)
AZURE_STORAGE_SAS_EXPIRY_HOURS="24"

# Google APIs Configuration
# Google Places API key for business search functionality
GOOGLE_PLACES_API_KEY=""

# OAuth Configuration (Optional - for future use)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# Redis Configuration (for WebSocket pub/sub and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_URL="redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# WebSocket Configuration
WEBSOCKET_MODE=false
WEBSOCKET_PORT=3001

# WebSocket Feature Flags
# Enable WebSocket-based message sending (default: true, set to false to use HTTP REST)
# Note: Real-time receiving (incoming messages, typing, presence) always works via WebSocket
ENABLE_WEBSOCKET_MESSAGES=true

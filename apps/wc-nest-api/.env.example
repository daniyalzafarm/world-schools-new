# Server Configuration
PORT=3000
NODE_ENV=development
# Set by the deploy pipeline from the `wc-v*` git tag; defaults to `dev` locally
APP_VERSION=dev

# Application URLs
# Public-facing API URL (used by Stripe service for Connect onboarding return/refresh links)
APP_URL="http://localhost:3000"
SUPERADMIN_PORTAL_URL="http://localhost:4301"
PROVIDER_PORTAL_URL="http://localhost:4302"
BOOKING_PORTAL_URL="http://localhost:4303"

# CORS Configuration
CORS_ORIGINS="http://localhost:3000,http://localhost:4200"

# Bull Board (BullMQ dashboard) credentials
BULL_BOARD_USER=user@world-camps.org
BULL_BOARD_PASSWORD=password123

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wc-booking-system
POSTGRES_REQUIRE_SSL=false
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# When true, JWT strategy resolves the user via the incoming request rather than the verified token payload
AUTH_USING_REQUEST=false
# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS="10"

# Security
HELMET_ENABLED=true
TRUST_PROXY=false

# Rate limit guard: when Redis is unavailable, 'open' = allow requests (default), 'closed' = return 503
RATE_LIMIT_FAIL_MODE=open

# Email Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="noreply@worldschools.com"

# Azure Storage Configuration
# Azure Storage account url (e.g., "https://wcstorageaccount.blob.core.windows.net")
AZURE_STORAGE_ACCOUNT_URL=""
# Azure Storage account name (e.g., "wcstorageaccount")
AZURE_STORAGE_ACCOUNT_NAME=""
# Azure Storage account key (found in Azure Portal > Storage Account > Access Keys)
AZURE_STORAGE_ACCOUNT_KEY=""
# Container name for provider verification documents (e.g., "wc-staging-files")
AZURE_STORAGE_CONTAINER_NAME=""
# SAS token expiry duration in hours (default: 24 hours)
AZURE_STORAGE_SAS_EXPIRY_HOURS="24"

# Google APIs Configuration
# Google Places API key for business search functionality
GOOGLE_PLACES_API_KEY=""

# Redis Configuration (for WebSocket pub/sub and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_URL="redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# WebSocket Feature Flags
# Enable WebSocket-based message sending (default: true, set to false to use HTTP REST)
# Note: Real-time receiving (incoming messages, typing, presence) always works via WebSocket
ENABLE_WEBSOCKET_MESSAGES=true

# Stripe Configuration
# Use sk_test_*/pk_test_* locally; deploys require sk_live_*/pk_live_* in production (enforced at boot)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Webhook signing secret for the main endpoint (account events)
STRIPE_WEBHOOK_SECRET=""
# Webhook signing secret for the Connect-account endpoint (payment_intent.*, charge.*, refund.*, etc.)
STRIPE_CONNECT_WEBHOOK_SECRET=""
# Replay-window tolerance in seconds (default 300, capped at 3600)
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
# Retention for the StripeWebhookEvent dedup table (default 90 days)
STRIPE_WEBHOOK_EVENT_RETENTION_DAYS=90

# Billing (off-session balance-charge cron + auth-window monitor)
# Off-session retry attempts before terminal failure
BILLING_OFF_SESSION_MAX_ATTEMPTS=2
# Spacing between off-session retry attempts on a soft decline
BILLING_OFF_SESSION_RETRY_HOURS=24
# How long a `requires_action` row may sit before it is marked step-up abandoned
BILLING_OFF_SESSION_STEP_UP_WINDOW_HOURS=48
# Balance-charge cron pickup cadence — must match the `@Cron` literal on BalanceChargeCron.run
BILLING_BALANCE_CHARGE_CRON_MINUTES=30
# Days before card-brand auth-window expiry to email providers
BILLING_AUTH_EXPIRY_WARN_DAYS=5
# Days before expiry to force-cancel the auth (must be < 7 and > WARN_DAYS)
BILLING_AUTH_EXPIRY_CANCEL_DAYS=6

{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.nestjs.spec.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    // Match the build's ambient types (tsconfig.nestjs.json) so specs that import
    // controllers typed with `Express.Multer.File` type-check the same way the app does.
    "types": ["jest", "node", "multer"]
  },
  "include": [
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.d.ts"
  ]
}

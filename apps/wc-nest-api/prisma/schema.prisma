// GAP 14: Message Mentions
model MessageMention {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, createdAt])
  @@map("message_mentions")
}

// GAP 15: Message Bookmarks
model MessageBookmark {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, createdAt])
  @@map("message_bookmarks")
}

// GAP 25: Abuse Reporting
model MessageReport {
  id          String       @id @default(uuid())
  messageId   String       @map("message_id")
  reportedBy  String       @map("reported_by")
  reason      ReportReason
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  reviewedBy  String?      @map("reviewed_by")
  reviewedAt  DateTime?    @map("reviewed_at")
  resolution  String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")

  // Relations
  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter User    @relation("ReportedMessages", fields: [reportedBy], references: [id])
  reviewer User?   @relation("ReviewedReports", fields: [reviewedBy], references: [id])

  @@index([messageId])
  @@index([reportedBy])
  @@index([status])
  @@map("message_reports")
}

model MessageAttachment {
  id        String  @id @default(uuid())
  messageId String? @map("message_id") // null until attached to a message (upload-then-send)

  // File metadata
  fileName String   @map("file_name")
  fileSize Int      @map("file_size") // bytes
  mimeType String   @map("mime_type")
  fileType FileType @map("file_type")

  // Storage (paths; URLs built at read time from env, like camp images)
  storageUrl   String  @map("storage_url")
  thumbnailUrl String? @map("thumbnail_url")

  // Metadata
  uploadedBy String   @map("uploaded_by")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  // Relations
  message  Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploadedBy], references: [id])

  @@index([messageId])
  @@index([uploadedBy])
  @@map("message_attachments")
}

model TypingIndicator {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  startedAt      DateTime @default(now()) @map("started_at")
  expiresAt      DateTime @map("expires_at")

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([expiresAt])
  @@map("typing_indicators")
}

model UserPresence {
  userId     String         @id @map("user_id")
  status     PresenceStatus
  lastSeenAt DateTime       @default(now()) @map("last_seen_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lastSeenAt])
  @@map("user_presence")
}

// GAP 10: Conversation Labels
model ConversationLabel {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(50)
  color     String?  @db.VarChar(7) // Hex color code
  icon      String?  @db.VarChar(10) // Emoji
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  creator       User                          @relation(fields: [createdBy], references: [id])
  conversations ConversationLabelAssignment[]

  @@unique([name])
  @@map("conversation_labels")
}

model ConversationLabelAssignment {
  conversationId String   @map("conversation_id")
  labelId        String   @map("label_id")
  assignedBy     String   @map("assigned_by")
  assignedAt     DateTime @default(now()) @map("assigned_at")

  // Relations
  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label        ConversationLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  assigner     User              @relation(fields: [assignedBy], references: [id])

  @@id([conversationId, labelId])
  @@index([conversationId])
  @@index([labelId])
  @@map("conversation_label_assignments")
}

// ============================================
// Support Ticketing System Models
// ============================================

model SupportTicket {
  id           String  @id @default(uuid())
  ticketNumber String  @unique @map("ticket_number") @db.VarChar(30)
  subject      String  @db.VarChar(255)
  description  String? @db.Text // Optional original description from ticket creation form

  // Requester identity
  requesterType       SupportTicketRequesterType @map("requester_type")
  requesterUserId     String?                    @map("requester_user_id") // Parent/user ticket owner
  requesterProviderId String?                    @map("requester_provider_id") // Provider ticket owner
  createdByUserId     String                     @map("created_by_user_id") // Actor that created ticket
  sourceApp           SupportTicketSourceApp     @default(WC_BOOKING) @map("source_app")

  // Classification
  categoryId String?               @map("category_id")
  priority   SupportTicketPriority @default(NORMAL)
  status     SupportTicketStatus   @default(OPEN)
  tags       String[]              @default([])

  // Conversation integration
  conversationId String @unique @map("conversation_id")
  // App-level contract: conversations.context_type should be SUPPORT_TICKET and
  // conversations.context_id should equal this ticket's id.

  // Assignment
  assignedToUserId String?   @map("assigned_to_user_id")
  assignedByUserId String?   @map("assigned_by_user_id")
  assignedAt       DateTime? @map("assigned_at")

  // SLA + lifecycle milestones
  slaPolicyId                String?   @map("sla_policy_id")
  firstResponseDueAt         DateTime? @map("first_response_due_at")
  firstRespondedAt           DateTime? @map("first_responded_at")
  resolutionDueAt            DateTime? @map("resolution_due_at")
  resolvedAt                 DateTime? @map("resolved_at")
  closedAt                   DateTime? @map("closed_at")
  slaFirstResponseBreachedAt DateTime? @map("sla_first_response_breached_at")
  slaResolutionBreachedAt    DateTime? @map("sla_resolution_breached_at")

  // Resolution + closure
  resolvedByUserId     String?                      @map("resolved_by_user_id")
  resolutionCode       SupportTicketResolutionCode? @map("resolution_code")
  resolutionSummary    String?                      @map("resolution_summary") @db.Text
  closedByUserId       String?                      @map("closed_by_user_id")
  closureReason        String?                      @map("closure_reason") @db.Text
  reopenedCount        Int                          @default(0) @map("reopened_count")
  lastReopenedAt       DateTime?                    @map("last_reopened_at")
  lastReopenedByUserId String?                      @map("last_reopened_by_user_id")

  // Conversation reply cache for inbox ordering / filters
  lastRequesterReplyAt DateTime? @map("last_requester_reply_at")
  lastSupportReplyAt   DateTime? @map("last_support_reply_at")

  // Optional entity links seen in support UI
  bookingId String? @map("booking_id")
  campId    String? @map("camp_id")
  sessionId String? @map("session_id")

  // CSAT
  satisfactionScore             Int?      @map("satisfaction_score") // 1..5
  satisfactionComment           String?   @map("satisfaction_comment") @db.Text
  satisfactionSubmittedAt       DateTime? @map("satisfaction_submitted_at")
  satisfactionSubmittedByUserId String?   @map("satisfaction_submitted_by_user_id")

  metadata Json?

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")
  deletedAt  DateTime? @map("deleted_at")

  // Relations
  requesterUser           User?                            @relation("SupportTicketRequesterUser", fields: [requesterUserId], references: [id], onDelete: SetNull)
  requesterProvider       Provider?                        @relation("SupportTicketRequesterProvider", fields: [requesterProviderId], references: [id], onDelete: SetNull)
  createdByUser           User                             @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  category                SupportTicketCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  conversation            Conversation                     @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  assignedTo              User?                            @relation("SupportTicketAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  assignedBy              User?                            @relation("SupportTicketAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  slaPolicy               SupportTicketSlaPolicy?          @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)
  resolvedBy              User?                            @relation("SupportTicketResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  closedBy                User?                            @relation("SupportTicketClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  lastReopenedBy          User?                            @relation("SupportTicketLastReopenedBy", fields: [lastReopenedByUserId], references: [id], onDelete: SetNull)
  booking                 Booking?                         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  camp                    Camp?                            @relation(fields: [campId], references: [id], onDelete: SetNull)
  session                 Session?                         @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  satisfactionSubmittedBy User?                            @relation("SupportTicketSatisfactionBy", fields: [satisfactionSubmittedByUserId], references: [id], onDelete: SetNull)
  statusHistory           SupportTicketStatusHistory[]
  assignmentHistory       SupportTicketAssignmentHistory[]

  @@index([status, priority, createdAt(sort: Desc)])
  @@index([requesterType, status, createdAt(sort: Desc)])
  @@index([assignedToUserId, status, updatedAt(sort: Desc)])
  @@index([categoryId])
  @@index([slaPolicyId])
  @@index([requesterUserId])
  @@index([requesterProviderId])
  @@index([bookingId])
  @@index([campId])
  @@index([sessionId])
  @@index([resolvedAt])
  @@index([closedAt])
  @@index([lastRequesterReplyAt])
  @@index([lastSupportReplyAt])
  @@index([deletedAt])
  @@map("support_tickets")
}

model SupportTicketCategory {
  id                 String                 @id @default(uuid())
  key                String                 @unique @db.VarChar(60)
  name               String                 @db.VarChar(120)
  description        String?                @db.Text
  audience           SupportTicketAudience  @default(BOTH)
  isActive           Boolean                @default(true) @map("is_active")
  sortOrder          Int                    @default(0) @map("sort_order")
  defaultPriority    SupportTicketPriority? @map("default_priority")
  defaultSlaPolicyId String?                @map("default_sla_policy_id")
  metadata           Json?
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  // Relations
  tickets          SupportTicket[]
  defaultSlaPolicy SupportTicketSlaPolicy? @relation(fields: [defaultSlaPolicyId], references: [id], onDelete: SetNull)

  @@index([audience, isActive])
  @@index([sortOrder])
  @@index([defaultSlaPolicyId])
  @@map("support_ticket_categories")
}

model SupportTicketSlaPolicy {
  id                         String   @id @default(uuid())
  name                       String   @unique @db.VarChar(120)
  description                String?  @db.Text
  firstResponseTargetMinutes Int      @map("first_response_target_minutes")
  resolutionTargetMinutes    Int      @map("resolution_target_minutes")
  businessHoursOnly          Boolean  @default(true) @map("business_hours_only")
  businessTimeZone           String?  @map("business_time_zone") @db.VarChar(64)
  pauseOnPendingRequester    Boolean  @default(true) @map("pause_on_pending_requester")
  isActive                   Boolean  @default(true) @map("is_active")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  // Relations
  tickets    SupportTicket[]
  categories SupportTicketCategory[]

  @@index([isActive])
  @@map("support_ticket_sla_policies")
}

model SupportTicketStatusHistory {
  id              String               @id @default(uuid())
  ticketId        String               @map("ticket_id")
  fromStatus      SupportTicketStatus? @map("from_status")
  toStatus        SupportTicketStatus  @map("to_status")
  changedByUserId String?              @map("changed_by_user_id")
  changeReason    String?              @map("change_reason") @db.Text
  metadata        Json?
  changedAt       DateTime             @default(now()) @map("changed_at")

  // Relations
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedByUser User?         @relation("SupportTicketStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, changedAt(sort: Desc)])
  @@index([toStatus, changedAt(sort: Desc)])
  @@index([changedByUserId])
  @@map("support_ticket_status_history")
}

model SupportTicketAssignmentHistory {
  id                 String   @id @default(uuid())
  ticketId           String   @map("ticket_id")
  fromAssigneeUserId String?  @map("from_assignee_user_id")
  toAssigneeUserId   String?  @map("to_assignee_user_id")
  changedByUserId    String?  @map("changed_by_user_id")
  assignmentReason   String?  @map("assignment_reason") @db.Text
  assignedAt         DateTime @default(now()) @map("assigned_at")

  // Relations
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromAssignee  User?         @relation("SupportTicketAssignmentFromUser", fields: [fromAssigneeUserId], references: [id], onDelete: SetNull)
  toAssignee    User?         @relation("SupportTicketAssignmentToUser", fields: [toAssigneeUserId], references: [id], onDelete: SetNull)
  changedByUser User?         @relation("SupportTicketAssignmentChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, assignedAt(sort: Desc)])
  @@index([toAssigneeUserId, assignedAt(sort: Desc)])
  @@index([changedByUserId])
  @@map("support_ticket_assignment_history")
}

// ============================================
// Support Ticketing System Enums
// ============================================

enum SupportTicketRequesterType {
  PARENT
  PROVIDER
}

enum SupportTicketSourceApp {
  WC_BOOKING
  WC_PROVIDER
  WC_SUPERADMIN
  API
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_REQUESTER // Waiting on parent/provider response
  PENDING_SUPPORT // Waiting on support/internal dependency
  RESOLVED // Marked fixed/answered; can still be reopened
  CLOSED // Final terminal state
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketAudience {
  PARENT
  PROVIDER
  BOTH
}

enum SupportTicketResolutionCode {
  FIXED
  ANSWERED
  WORKAROUND_PROVIDED
  DUPLICATE
  REFUNDED
  POLICY_APPLIED
  CANNOT_REPRODUCE
  USER_NO_RESPONSE
  OTHER
}

// ============================================
// Messaging System Enums
// ============================================

enum ConversationType {
  USER_PROVIDER // Parent/User ↔ Camp Provider
  USER_SUPERADMIN // Parent/User ↔ Platform Support
  PROVIDER_SUPERADMIN // Provider ↔ Platform Support (future)
}

enum SenderType {
  USER
  PROVIDER
  SUPERADMIN
  CHATBOT
  SYSTEM
}

enum ContentType {
  TEXT
  IMAGE
  FILE
  VIDEO
  AUDIO
}

enum MessageType {
  REGULAR
  TRANSFER_REQUEST
  TRANSFER_SUMMARY
  SYSTEM_NOTIFICATION
  CHATBOT_RESPONSE
}

enum MessageStatus {
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum FileType {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  OTHER
}

enum PresenceStatus {
  ONLINE
  AWAY
  OFFLINE
}

// GAP 5: Context Type
enum ContextType {
  BOOKING
  CAMP
  PROVIDER
  SUPPORT_TICKET
  GENERAL
}

// GAP 7: Deletion Type
enum DeletionType {
  USER_DELETED // User deleted their own message
  ADMIN_DELETED // Admin/moderator deleted
  AUTO_DELETED // Auto-deleted (retention policy)
  GDPR_DELETED // GDPR right to be forgotten
}

// GAP 11: Message Priority
enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// GAP 13: Conversation Status
enum ConversationStatus {
  OPEN // Active conversation
  PENDING // Waiting for user response
  RESOLVED // Issue resolved, awaiting confirmation
  CLOSED // Conversation closed
  ARCHIVED // Archived for reference
}

// GAP 25: Report Reason
enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  SCAM
  IMPERSONATION
  OTHER
}

// GAP 25: Report Status
enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

// ============================================
// Knowledge Base
// ============================================

model ArticleCategory {
  id          String  @id @default(uuid())
  name        String  @unique @db.VarChar(100)
  slug        String  @unique @db.VarChar(150)
  description String? @db.Text
  icon        String? @db.VarChar(10) // Emoji or icon identifier
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  articles Article[]

  @@index([isActive])
  @@index([sortOrder])
  @@index([isActive, sortOrder]) // Composite index for filtering active categories in order
  @@map("article_categories")
}

model Article {
  id          String        @id @default(uuid())
  title       String        @db.VarChar(255)
  slug        String        @unique @db.VarChar(300)
  articleType ArticleType   @map("article_type")
  audience    Audience[]
  categoryId  String        @map("category_id")
  status      ArticleStatus @default(draft)

  // Content
  contentHtml String  @map("content_html") @db.Text
  summary     String? @db.Text // Brief excerpt for article listings and previews

  // SEO & Schema
  metaTitle       String @map("meta_title") @db.VarChar(255)
  metaDescription String @map("meta_description") @db.VarChar(500)

  // Author & Publishing
  author        String    @db.VarChar(255)
  publishedAt   DateTime? @map("published_at")
  lastUpdatedAt DateTime? @map("last_updated_at")

  // Analytics (denormalized counters for performance)
  views           Int @default(0)
  helpfulCount    Int @default(0) @map("helpful_count")
  notHelpfulCount Int @default(0) @map("not_helpful_count")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  category    ArticleCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  relatedFrom ArticleRelation[] @relation("ArticleRelations") // Articles this article links to
  relatedTo   ArticleRelation[] @relation("RelatedToArticles") // Articles that link to this article
  feedback    ArticleFeedback[] // Individual feedback votes

  @@index([status])
  @@index([slug])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([categoryId, status]) // Composite index for filtering articles by category and status
  @@index([categoryId, publishedAt]) // Composite index for category pages with date sorting
  @@map("articles")
}

model ArticleRelation {
  id               String   @id @default(uuid())
  articleId        String   @map("article_id")
  relatedArticleId String   @map("related_article_id")
  sortOrder        Int      @default(0) @map("sort_order") // For ordering related articles in display
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  article        Article @relation("ArticleRelations", fields: [articleId], references: [id], onDelete: Cascade)
  relatedArticle Article @relation("RelatedToArticles", fields: [relatedArticleId], references: [id], onDelete: Cascade)

  @@unique([articleId, relatedArticleId]) // Prevent duplicate relations
  @@index([articleId])
  @@index([relatedArticleId])
  @@index([articleId, sortOrder]) // Optimize fetching ordered related articles
  @@map("article_relations")
}

model ArticleFeedback {
  id        String   @id @default(uuid())
  articleId String   @map("article_id")
  userId    String?  @map("user_id") // Nullable for anonymous users
  sessionId String?  @map("session_id") // For tracking anonymous user votes
  isHelpful Boolean  @map("is_helpful") // true = helpful, false = not helpful
  ipAddress String?  @map("ip_address") // For rate limiting and abuse prevention
  userAgent String?  @map("user_agent") // Additional tracking metadata
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([articleId, userId]) // Prevent duplicate votes from authenticated users
  @@unique([articleId, sessionId]) // Prevent duplicate votes from anonymous users
  @@index([articleId])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([articleId, isHelpful]) // Optimize counting helpful/not helpful votes
  @@map("article_feedback")
}

// ============================================
// Knowledge Base Enums
// ============================================

enum ArticleType {
  how_to
  faq
  reference
  policy

  @@map("article_type")
}

enum Audience {
  parents
  providers
  staff

  @@map("audience")
}

enum ArticleStatus {
  draft
  published
  archived

  @@map("article_status")
}

// Add-ons
// ============================================

model AddOn {
  id         String @id @default(uuid())
  providerId String @map("provider_id")

  // Basic Info
  name        String    @db.VarChar(120)
  description String?   @db.Text
  icon        String?   @db.VarChar(10) // Emoji
  type        AddOnType

  // Pricing
  price       Decimal     @db.Decimal(10, 2)
  currency    String      @default("CHF") @db.VarChar(3)
  pricingUnit PricingUnit

  // Quantity Limits
  maxQuantity  Int?    @map("max_quantity")
  quantityUnit String? @map("quantity_unit") @db.VarChar(50) // e.g., "per week"

  // Age Restrictions
  minAge Int? @map("min_age")
  maxAge Int? @map("max_age")

  // Status & Ordering
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  provider   Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  campAddOns CampAddOn[]

  @@index([providerId])
  @@index([type])
  @@index([isActive])
  @@index([sortOrder])
  @@map("add_ons")
}

// Junction table for many-to-many relationship between Camps and AddOns
model CampAddOn {
  campId    String  @map("camp_id")
  addOnId   String  @map("add_on_id")
  isEnabled Boolean @default(true) @map("is_enabled") // Toggle on/off for specific camp
  sortOrder Int     @default(0) @map("sort_order") // Camp-specific ordering

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  camp          Camp               @relation(fields: [campId], references: [id], onDelete: Cascade)
  addOn         AddOn              @relation(fields: [addOnId], references: [id], onDelete: Cascade)
  bookingAddOns BookingCampAddOn[]

  @@id([campId, addOnId])
  @@index([campId])
  @@index([addOnId])
  @@map("camp_add_ons")
}

/// Selected add-ons for a specific child booking.
/// Stores a JSON snapshot for audit/UI, plus numeric fields for safe aggregation.
model BookingCampAddOn {
  bookingId String @map("booking_id")

  /// References `CampAddOn`'s composite PK.
  campId  String @map("camp_id")
  addOnId String @map("add_on_id")

  quantity  Int     @default(1) @map("quantity")
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  lineTotal Decimal @map("line_total") @db.Decimal(12, 2)

  /// Snapshot of the add-on selection (e.g. config, quantity basis, UI metadata).
  snapshot Json @map("snapshot") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  campAddOn CampAddOn @relation(fields: [campId, addOnId], references: [campId, addOnId], onDelete: Restrict)

  @@id([bookingId, campId, addOnId])
  @@index([campId])
  @@index([addOnId])
  @@map("booking_camp_add_ons")
}

enum AddOnType {
  activity
  service
  equipment
  language
}

enum PricingUnit {
  per_child
  per_hour
  per_session
  per_week
  per_bag
  one_time
}

// ============================================
// Messaging System Models
// ============================================

model Conversation {
  id            String           @id @default(uuid())
  type          ConversationType
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  lastMessageId String?          @unique @map("last_message_id")

  // Context & Metadata (GAP 5)
  subject     String?      @db.VarChar(255)
  contextType ContextType? @map("context_type")
  contextId   String?      @map("context_id")
  metadata    Json?

  // Assignment (GAP 12)
  assignedToId String?   @map("assigned_to_id")
  assignedAt   DateTime? @map("assigned_at")
  assignedBy   String?   @map("assigned_by")

  // Status tracking (GAP 13)
  status              ConversationStatus @default(OPEN)
  openedAt            DateTime           @default(now()) @map("opened_at")
  statusChangedAt     DateTime?          @map("status_changed_at")
  statusChangedByUser String?            @map("status_changed_by")

  // Cached metrics (GAP 28)
  messageCount     Int      @default(0) @map("message_count")
  participantCount Int      @default(0) @map("participant_count")
  avgResponseTime  Int?     @map("avg_response_time") // seconds
  lastActivityAt   DateTime @default(now()) @map("last_activity_at")

  // Relations
  participants       ConversationParticipant[]
  messages           Message[]
  lastMessage        Message?                      @relation("LastMessage", fields: [lastMessageId], references: [id])
  labels             ConversationLabelAssignment[]
  assignedTo         User?                         @relation("AssignedConversations", fields: [assignedToId], references: [id], onDelete: SetNull)
  assigner           User?                         @relation("AssignedByUser", fields: [assignedBy], references: [id])
  statusChangedByRel User?                         @relation("StatusChangedByUser", fields: [statusChangedByUser], references: [id])
  supportTicket      SupportTicket?

  @@index([type])
  @@index([updatedAt])
  @@index([contextType, contextId])
  @@index([assignedToId])
  @@index([assignedAt])
  @@index([status, updatedAt])
  @@index([lastActivityAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String  @id @default(uuid())
  conversationId String  @map("conversation_id")
  userId         String  @map("user_id")
  providerId     String? @map("provider_id") // For provider participants

  // Participant-specific settings
  pinned     Boolean   @default(false)
  pinnedAt   DateTime? @map("pinned_at")
  starred    Boolean   @default(false)
  muted      Boolean   @default(false)
  archived   Boolean   @default(false)
  archivedAt DateTime? @map("archived_at")

  // Read tracking
  lastReadAt  DateTime? @map("last_read_at")
  unreadCount Int       @default(0) @map("unread_count")

  // Auto-response settings (GAP 17)
  autoResponseEnabled Boolean   @default(false) @map("auto_response_enabled")
  autoResponseMessage String?   @map("auto_response_message") @db.Text
  autoResponseUntil   DateTime? @map("auto_response_until")
  businessHoursOnly   Boolean   @default(false) @map("business_hours_only")

  // Rate limiting (GAP 26)
  messageCount24h Int       @default(0) @map("message_count_24h")
  lastMessageAt   DateTime? @map("last_message_at")
  isRateLimited   Boolean   @default(false) @map("is_rate_limited")
  rateLimitUntil  DateTime? @map("rate_limit_until")

  // Metadata
  joinedAt DateTime  @default(now()) @map("joined_at")
  leftAt   DateTime? @map("left_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     Provider?    @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([providerId])
  @@index([conversationId, lastReadAt])
  @@index([isRateLimited])
  @@map("conversation_participants")
}

model Message {
  id             String     @id @default(uuid())
  conversationId String     @map("conversation_id")
  senderId       String     @map("sender_id")
  senderType     SenderType @map("sender_type")

  // Message content
  content     String      @db.Text
  contentType ContentType @default(TEXT) @map("content_type")

  // Message metadata
  type     MessageType @default(REGULAR)
  metadata Json? // For transfer requests, system messages, etc.

  // Reply/Threading support (GAP 1)
  replyToId String? @map("reply_to_id")

  // Forwarding support (GAP 9)
  forwardedFromId String? @map("forwarded_from_id")
  forwardCount    Int     @default(0) @map("forward_count")

  // Priority & Pinning (GAP 11)
  isPinned Boolean          @default(false) @map("is_pinned")
  pinnedAt DateTime?        @map("pinned_at")
  pinnedBy String?          @map("pinned_by")
  priority MessagePriority? @default(NORMAL)

  // Scheduling support (GAP 18)
  scheduledFor DateTime? @map("scheduled_for")
  scheduledBy  String?   @map("scheduled_by")
  isScheduled  Boolean   @default(false) @map("is_scheduled")

  // Status tracking
  status      MessageStatus @default(SENT)
  deliveredAt DateTime?     @map("delivered_at")
  readAt      DateTime?     @map("read_at")

  // Performance tracking (GAP 27)
  sentAt            DateTime @default(now()) @map("sent_at")
  deliveryLatencyMs Int?     @map("delivery_latency_ms")

  // Edit/Delete tracking (GAP 7 - Enhanced)
  editedAt     DateTime?     @map("edited_at")
  deletedAt    DateTime?     @map("deleted_at")
  deletedBy    String?       @map("deleted_by")
  isDeleted    Boolean       @default(false) @map("is_deleted")
  deletionType DeletionType? @map("deletion_type")

  // Full-text search support (GAP 6)
  searchVector Unsupported("tsvector")? @map("search_vector")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  conversation       Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender             User                     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  lastMessageFor     Conversation?            @relation("LastMessage")
  readReceipts       MessageReadReceipt[]
  deliveryReceipts   MessageDeliveryReceipt[] // GAP 3
  reactions          MessageReaction[] // GAP 4
  editHistory        MessageEditHistory[] // GAP 8
  mentions           MessageMention[] // GAP 14
  bookmarks          MessageBookmark[] // GAP 15
  reports            MessageReport[] // GAP 25
  replyTo            Message?                 @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies            Message[]                @relation("MessageReplies")
  forwardedFrom      Message?                 @relation("MessageForwards", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwards           Message[]                @relation("MessageForwards")
  messageAttachments MessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([conversationId, createdAt(sort: Desc), id]) // GAP 2 - Cursor pagination
  @@index([senderId])
  @@index([status])
  @@index([createdAt])
  @@index([replyToId])
  @@index([forwardedFromId])
  @@index([conversationId, isPinned, createdAt])
  @@index([scheduledFor])
  @@index([isScheduled, scheduledFor])
  @@index([isDeleted, conversationId, createdAt])
  @@index([sentAt])
  @@index([searchVector], type: Gin) // GAP 6 - Full-text search
  @@map("messages")
}

model MessageReadReceipt {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])

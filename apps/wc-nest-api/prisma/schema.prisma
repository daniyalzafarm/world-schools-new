  /// Optional list of specific activities within this category.
  specificActivityIds String[] @default([]) @map("specific_activity_ids")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  camp     Camp             @relation(fields: [campId], references: [id], onDelete: Cascade)
  category ActivityCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([campId, categoryId])
  @@index([campId])
  @@index([categoryId])
  @@map("camp_interests")
}

/// Camp's skill requirements for eligibility or grouping.
model CampEligibilityRequirement {

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// User Management & Authentication
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String?   @map("password_hash")
  passwordChangedAt DateTime? @map("password_changed_at")
  firstName         String?   @map("first_name")
  lastName          String?   @map("last_name")
  emailVerified     Boolean   @default(false) @map("email_verified")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  profilePhotoUrl   String?   @map("profile_photo_url")
  phone             String?
  phoneVerified     Boolean   @default(false) @map("phone_verified")
  address           String?
  city              String?
  state             String?
  postalCode        String?   @map("postal_code")
  country           String?
  bio               String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  userAccounts         UserAccount[]
  roles                UserRole[]
  parentProfile        Parent?
  ownedProvider        Provider?
  approvedProviders    Provider[]             @relation("ApprovedProviders")
  reviewedApplications Provider[]             @relation("ReviewedApplications")
  emailVerifications   EmailVerification[]
  passwordResets       PasswordReset[]
  reviewedDocuments    VerificationDocument[] @relation("ReviewedDocuments")
  twoFactorAuth        TwoFactorAuth?
  sessions             UserSession[]

  // Messaging Relations
  conversationParticipants   ConversationParticipant[]
  sentMessages               Message[]
  messageReadReceipts        MessageReadReceipt[]
  uploadedAttachments        MessageAttachment[]
  presence                   UserPresence?
  messageDeliveryReceipts    MessageDeliveryReceipt[]
  messageReactions           MessageReaction[]
  messageEdits               MessageEditHistory[]          @relation("MessageEditor")
  messageMentions            MessageMention[]
  messageBookmarks           MessageBookmark[]
  reportedMessages           MessageReport[]               @relation("ReportedMessages")
  reviewedReports            MessageReport[]               @relation("ReviewedReports")
  createdLabels              ConversationLabel[]
  assignedLabels             ConversationLabelAssignment[]
  assignedConversations      Conversation[]                @relation("AssignedConversations")
  conversationsAssigned      Conversation[]                @relation("AssignedByUser")
  statusChangedConversations Conversation[]                @relation("StatusChangedByUser")

  // Knowledge Base Relations
  articleFeedback ArticleFeedback[]

  // Support Ticketing Relations
  supportTicketsCreated          SupportTicket[]                  @relation("SupportTicketCreatedBy")
  supportTicketsRequested        SupportTicket[]                  @relation("SupportTicketRequesterUser")
  supportTicketsAssigned         SupportTicket[]                  @relation("SupportTicketAssignedTo")
  supportTicketsAssignedBy       SupportTicket[]                  @relation("SupportTicketAssignedBy")
  supportTicketsResolved         SupportTicket[]                  @relation("SupportTicketResolvedBy")
  supportTicketsClosed           SupportTicket[]                  @relation("SupportTicketClosedBy")
  supportTicketsReopened         SupportTicket[]                  @relation("SupportTicketLastReopenedBy")
  supportTicketStatusChanges     SupportTicketStatusHistory[]     @relation("SupportTicketStatusChangedBy")
  supportTicketAssignmentChanges SupportTicketAssignmentHistory[] @relation("SupportTicketAssignmentChangedBy")
  supportTicketAssignmentFrom    SupportTicketAssignmentHistory[] @relation("SupportTicketAssignmentFromUser")
  supportTicketAssignmentTo      SupportTicketAssignmentHistory[] @relation("SupportTicketAssignmentToUser")
  supportTicketSatisfactionBy    SupportTicket[]                  @relation("SupportTicketSatisfactionBy")

  @@map("users")
}

model UserAccount {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  type                  String
  authProvider          String   @map("auth_provider")
  authProviderAccountId String   @map("auth_provider_account_id")
  refreshToken          String?  @map("refresh_token") @db.Text
  accessToken           String?  @map("access_token") @db.Text
  expiresAt             Int?     @map("expires_at")
  tokenType             String?  @map("token_type")
  scope                 String?
  idToken               String?  @map("id_token") @db.Text
  sessionState          String?  @map("session_state")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([authProvider, authProviderAccountId])
  @@index([userId])
  @@map("user_accounts")
}

// ============================================
// RBAC (Role-Based Access Control)
// ============================================

model Role {
  id           String   @id @default(uuid())
  name         String
  isSystemRole Boolean  @default(false) @map("is_system_role")
  providerId   String?  @map("provider_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  provider    Provider?        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([name, providerId])
  @@index([providerId])
  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Permission {
  id        String   @id
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ============================================
// Provider (Organization)
// ============================================

model Provider {
  id                 String   @id @default(uuid())
  ownerId            String   @unique @map("owner_id")
  legalCompanyName   String?  @map("legal_company_name")
  legalStreetAddress String?  @map("legal_street_address")
  legalAptSuite      String?  @map("legal_apt_suite")
  legalCity          String?  @map("legal_city")
  legalStateProvince String?  @map("legal_state_province")
  legalPostalCode    String?  @map("legal_postal_code")
  legalCountry       String?  @map("legal_country")
  yearFounded        Int?     @map("year_founded")
  phone              String?
  email              String?
  website            String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Contact & Account (Step 2)
  contactFirstName String? @map("contact_first_name")
  contactLastName  String? @map("contact_last_name")
  contactRole      String? @map("contact_role")
  contactPhone     String? @map("contact_phone")
  contactEmail     String? @map("contact_email")

  // Camp Details (Step 3)
  description String? @db.Text
  campType    String? @map("camp_type")

  // Approval Status
  trustScore          Int?           @map("trust_score")
  trustScoreBreakdown Json?          @map("trust_score_breakdown")
  approvalStatus      ApprovalStatus @default(pending) @map("approval_status")
  approvalDecisionAt  DateTime?      @map("approval_decision_at")
  approvedByAdminId   String?        @map("approved_by_admin_id")
  rejectionReason     String?        @map("rejection_reason") @db.Text
  rejectionCategory   String?        @map("rejection_category")

  // Application Review
  applicationSubmittedAt DateTime? @map("application_submitted_at")
  applicationReviewedAt  DateTime? @map("application_reviewed_at")
  applicationReviewedBy  String?   @map("application_reviewed_by")

  // Onboarding Progress
  onboardingStartedAt   DateTime? @map("onboarding_started_at")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  onboardingCurrentStep Int       @default(1) @map("onboarding_current_step")
  lastLoginAt           DateTime? @map("last_login_at")

  // Terms & Conditions Acceptance
  termsAcceptedAt             DateTime? @map("terms_accepted_at")
  termsVersion                String?   @map("terms_version")
  providerAgreementAcceptedAt DateTime? @map("provider_agreement_accepted_at")
  providerAgreementVersion    String?   @map("provider_agreement_version")

  // Relations
  owner                 User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  approvedByAdmin       User?                  @relation("ApprovedProviders", fields: [approvedByAdminId], references: [id])
  reviewedByUser        User?                  @relation("ReviewedApplications", fields: [applicationReviewedBy], references: [id])
  roles                 Role[]
  googleBusinessProfile GoogleBusinessProfile?
  settings              ProviderSettings?
  verificationDocuments VerificationDocument[]
  camps                 Camp[]
  bookings              Booking[]
  bookingGroups         BookingGroup[]
  addOns                AddOn[]

  // Messaging Relations
  conversationParticipants ConversationParticipant[]
  supportTicketsRequested  SupportTicket[]           @relation("SupportTicketRequesterProvider")

  @@index([ownerId])
  @@index([approvalStatus])
  @@index([approvedByAdminId])
  @@index([applicationReviewedBy])
  @@map("providers")
}

// ============================================
// Parent Profile
// ============================================

model Parent {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  primaryNationality   String?  @map("primary_nationality")
  secondaryNationality String?  @map("secondary_nationality")
  languages            String[] @default([])
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  children      Children[]
  bookings      Booking[]
  bookingGroups BookingGroup[]

  @@index([userId])
  @@map("parents")
}

// ============================================
// Children
// ============================================

model Children {
  id String @id @default(uuid())

  // Basic Information (30% weight)
  firstName     String    @map("first_name")
  lastName      String?   @map("last_name")
  nickname      String?
  dateOfBirth   DateTime? @map("date_of_birth")
  gender        String?
  photoUrl      String?   @map("photo_url")
  schoolYear    String?   @map("school_year")
  schoolCountry String?   @map("school_country")
  languages     String[]  @default([])

  // Medical Information (20% weight) - JSONB
  medicalInfo Json? @map("medical_info")

  // Emergency Contacts (25% weight) - JSONB array
  emergencyContacts Json @default("[]") @map("emergency_contacts")

  // Camp Preferences (15% weight) - JSONB
  campPreferences Json? @map("camp_preferences")

  // Profile Completion
  profileCompletion Int @default(0) @map("profile_completion")

  // Soft Delete
  archived Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // The parent this child belongs to
  parentId String @map("parent_id")
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  // Relations
  bookings       Booking[]
  childInterests ChildInterest[]
  childSkills    ChildSkill[]

  @@index([parentId])
  @@index([archived])
  @@map("children")
}

// ============================================
// Email Verification
// ============================================

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  type      String   @default("signup") // 'signup' or 'login_2fa'
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@index([type])
  @@index([expiresAt])
  @@map("email_verifications")
}

// ============================================
// Password Reset
// ============================================

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_resets")
}

// ============================================
// Two-Factor Authentication
// ============================================

model TwoFactorAuth {
  id        String    @id @default(uuid())
  userId    String    @unique @map("user_id")
  method    String // 'email' (only email for now)
  enabled   Boolean   @default(false)
  enabledAt DateTime? @map("enabled_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([enabled])
  @@map("two_factor_auth")
}

// ============================================
// User Sessions
// ============================================

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  sessionId    String   @unique @map("session_id")
  deviceType   String?  @map("device_type")
  deviceName   String?  @map("device_name")
  browser      String?
  os           String?
  ipAddress    String?  @map("ip_address")
  location     String?
  isRevoked    Boolean  @default(false) @map("is_revoked")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
  @@index([isRevoked])
  @@map("user_sessions")
}

// ============================================
// Provider Onboarding
// ============================================

model GoogleBusinessProfile {
  id         String @id @default(uuid())
  providerId String @unique @map("provider_id")

  // Google Places Data
  placeId          String @unique @map("place_id")
  businessName     String @map("business_name")
  formattedAddress String @map("formatted_address")

  // Address Components
  streetNumber String? @map("street_number")
  streetName   String? @map("street_name")
  city         String?
  state        String?
  postalCode   String? @map("postal_code")
  country      String?

  // Location
  lat Decimal @db.Decimal(10, 8)
  lng Decimal @db.Decimal(11, 8)

  // Business Info
  rating       Decimal? @db.Decimal(2, 1)
  reviewsCount Int?     @map("reviews_count")
  phone        String?
  website      String?

  // Additional Data
  photos  Json? // Array of photo references
  types   Json? // Array of business types
  dataRaw Json? @map("data_raw") // Full API response

  fetchedAt DateTime @default(now()) @map("fetched_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("google_business_profiles")
}

model ProviderSettings {
  id         String @id @default(uuid())
  providerId String @unique @map("provider_id")

  // Regional Settings
  currency String // ISO 4217 currency code
  timezone String // IANA timezone

  // Deposit Settings
  depositRequired    Boolean  @default(false) @map("deposit_required")
  depositType        String?  @map("deposit_type") // 'percentage' | 'fixed'
  depositPercentage  Int?     @map("deposit_percentage")
  depositFixedAmount Decimal? @map("deposit_fixed_amount") @db.Decimal(10, 2)

  // Cancellation Policy
  cancellationPolicy       String @default("moderate") @map("cancellation_policy") // 'flexible' | 'moderate' | 'strict' | 'custom'
  cancellationPolicyCustom Json?  @map("cancellation_policy_custom")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_settings")
}

model VerificationDocument {
  id            String  @id @default(uuid())
  providerId    String  @map("provider_id")
  documentType  String  @map("document_type") // Required: 'business_registration' | 'insurance_certificate' | Accreditations: 'aca' | 'icf' | 'bsa' | 'national_accreditation' | 'regional_accreditation' | 'other_accreditation' | Safety: 'risk_policy' | 'first_aid' | 'lifeguard' | 'background_check' | 'emergency_plan' | 'food_safety' | 'other_safety'
  customTitle   String? @map("custom_title") // For 'other_accreditation' and 'other_safety' types
  fileUrl       String  @map("file_url")
  fileName      String? @map("file_name")
  fileSizeBytes Int?    @map("file_size_bytes")
  mimeType      String? @map("mime_type")

  // Review & Verification
  reviewStatus      DocumentReviewStatus @default(pending) @map("review_status")
  reviewedByAdminId String?              @map("reviewed_by_admin_id")
  reviewedAt        DateTime?            @map("reviewed_at")
  reviewChecklist   Json?                @map("review_checklist")
  reviewNotes       String?              @map("review_notes") @db.Text
  rejectionReason   String?              @map("rejection_reason") @db.Text

  uploadedAt DateTime @default(now()) @map("uploaded_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  provider        Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?    @relation("ReviewedDocuments", fields: [reviewedByAdminId], references: [id])

  @@index([providerId])
  @@index([documentType])
  @@map("verification_documents")
}

// ============================================
// Camps Management
// ============================================

model Camp {
  id         String @id @default(uuid())
  providerId String @map("provider_id")

  // Basic Info (Step 1 - Wizard & Editor)
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(150)
  type        CampType
  description String   @db.Text

  // Location
  locationType    LocationType
  locationPlaceId String?      @map("location_place_id")
  locationName    String?      @map("location_name")
  locationAddress String?      @map("location_address") @db.Text
  locationLat     Decimal?     @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal?     @map("location_lng") @db.Decimal(11, 8)

  // Audience (Step 2 - Wizard & Editor)
  ageGroups Json // [{min: 6, max: 17}, ...]
  languages String[] // ['english', 'french', ...]
  gender    Gender

  // Programs (Step 3 - Wizard & Editor)
  activities String[] // ['sports', 'water', 'arts', ...]

  // Photos (Step 4 - Wizard, Editor has separate section)
  photos Json? // [{id, url, thumbnail, isPrimary}, ...]

  // Editor-only fields
  whatsIncluded           Json? // {items: string[], customItems: string[]}
  scheduleType            String? // 'daily' | 'weekly' | null
  dailySchedule           Json? // For daily schedule data
  weeklySchedule          Json? // For weekly schedule data
  meals                   Json? // {breakfast, lunch, dinner, snacks, dietary}
  sportsActivities        Json? // {selected: string[], details: {...}}
  languagePrograms        Json? // {selected: string[], details: {...}}
  artsAndCrafts           Json? // {selected: string[], details: {...}}
  adventureActivities     Json?
  waterActivities         Json?
  environmentalActivities Json?
  academics               Json?
  religionPrograms        Json?
  excursionsTrips         Json?
  campusFacilities        Json? // {facilities: string[], description}
  accommodation           Json? // {type, rooms, amenities}
  gettingThere            Json? // {directions, transportation}
  campFocus               Json? // {primaryFocus: {activityId, activityName, categoryId, categoryName, icon}, description, philosophy, learningApproach}

  // Publishing
  status      CampStatus @default(draft)
  publishedAt DateTime?  @map("published_at")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  provider                Provider                     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  campAddOns              CampAddOn[]
  sessions                Session[]
  globalDiscounts         GlobalDiscount[]
  supportTickets          SupportTicket[]
  bookings                Booking[]
  bookingGroups           BookingGroup[]
  campFocusRecord         CampFocus?
  campInterests           CampInterest[]
  eligibilityRequirements CampEligibilityRequirement[]

  @@index([providerId])
  @@index([status])
  @@index([slug])
  @@map("camps")
}

// ============================================
// Activity Catalogue & Matching
// ============================================

/// Top-level interest / activity category configured by superadmin.
model ActivityCategory {
  id     String                 @id @default(uuid())
  /// Stable slug used by frontend (e.g. "sports")
  slug   String                 @unique @db.VarChar(80)
  name   String                 @db.VarChar(120)
  emoji  String?                @db.VarChar(8)
  status ActivityCategoryStatus @default(ACTIVE)

  // Surfaces – control where this category appears
  surfaceParentInterests Boolean @default(true) @map("surface_parent_interests")
  surfaceCampFocus       Boolean @default(true) @map("surface_camp_focus")
  surfaceCampInterests   Boolean @default(true) @map("surface_camp_interests")

  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  activities     Activity[]
  childInterests ChildInterest[]
  campInterests  CampInterest[]
  campFocuses    CampFocus[]

  @@index([status, order])
  @@map("activity_categories")
}

/// Individual activity within a category (e.g. Football, Piano).
model Activity {
  id         String   @id @default(uuid())
  categoryId String   @map("category_id")
  slug       String   @db.VarChar(80)
  name       String   @db.VarChar(120)
  emoji      String?  @db.VarChar(8)
  scaleId    String?  @map("scale_id")
  order      Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category        ActivityCategory             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  scale           ActivityScale?               @relation(fields: [scaleId], references: [id], onDelete: SetNull)
  childSkills     ChildSkill[]
  campEligibility CampEligibilityRequirement[]
  campFocuses     CampFocus[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([scaleId])
  @@index([isActive])
  @@map("activities")
}

/// Scale definition (e.g. standard-3, standard-5, CEFR, swim-4).
model ActivityScale {
  id          String  @id @db.VarChar(80)
  name        String  @db.VarChar(160)
  description String? @db.Text

  /// Visual style used by frontend pickers (e.g. DOT or GRID).
  visualType ActivityScaleVisualType @default(DOT) @map("visual_type")
  /// Color token for UI variants (e.g. PURPLE, TEAL, AMBER).
  colorKey   ActivityScaleColorKey   @default(PURPLE) @map("color_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  levels     ActivityScaleLevel[]
  activities Activity[]

  @@map("activity_scales")
}

/// Individual level within a scale (ordered for comparisons).
model ActivityScaleLevel {
  id      String @id @default(uuid())
  scaleId String @map("scale_id")
  /// Canonical stored value used in APIs (e.g. "A1", "Beginner").
  value   String @db.VarChar(80)
  label   String @db.VarChar(160)
  /// Order used for >= comparisons (1 = lowest).
  order   Int

  scale ActivityScale @relation(fields: [scaleId], references: [id], onDelete: Cascade)

  @@unique([scaleId, value])
  @@index([scaleId, order])
  @@map("activity_scale_levels")
}

/// Child's interests at category + optional specific activities level.
model ChildInterest {
  id                  String   @id @default(uuid())
  childId             String   @map("child_id")
  categoryId          String   @map("category_id")
  /// Optional list of specific activity IDs within this category.
  specificActivityIds String[] @default([]) @map("specific_activity_ids")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  child    Children         @relation(fields: [childId], references: [id], onDelete: Cascade)
  category ActivityCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([childId, categoryId])
  @@index([childId])
  @@index([categoryId])
  @@map("child_interests")
}

/// Child's skill level for a specific activity.
model ChildSkill {
  id         String @id @default(uuid())
  childId    String @map("child_id")
  activityId String @map("activity_id")
  /// Must correspond to ActivityScaleLevel.value for the activity's scale.
  levelValue String @map("level_value") @db.VarChar(80)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  child    Children @relation(fields: [childId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Restrict)

  @@unique([childId, activityId])
  @@index([childId])
  @@index([activityId])

// ============================================
// Sessions & Bookings
// ============================================

/// Groups sibling bookings for a single parent; one payment flow per group.
/// All bookings in a group share the same payment/refund lifecycle.
model BookingGroup {
  id         String @id @default(uuid())
  bookingGroupNumber String @unique @map("booking_group_number") @db.VarChar(32)
  parentId   String @map("parent_id")
  sessionId  String @map("session_id")
  campId     String @map("camp_id")
  providerId String @map("provider_id")

  /// Monetary breakdown in booking currency.
  /// Sum of child line items before discounts.
  subtotalAmount  Decimal @map("subtotal_amount") @db.Decimal(12, 2)
  /// Total discount amount applied at group + line-item level.
  discountTotal   Decimal @default(0) @map("discount_total") @db.Decimal(12, 2)
  /// JSON snapshot of how discounts were calculated (for UI/debugging).
  discountDetails Json?   @map("discount_details") @db.JsonB
  /// Final amount due for the group (after discounts); intended PaymentIntent amount.
  totalAmount     Decimal @map("total_amount") @db.Decimal(12, 2)

  /// Deposit required (from provider settings); balance = totalAmount - depositAmount.
  depositAmount Decimal? @map("deposit_amount") @db.Decimal(10, 2)

  /// Aggregated payment tracking for the group.
  paidAmount     Decimal @default(0) @map("paid_amount") @db.Decimal(12, 2)
  refundedAmount Decimal @default(0) @map("refunded_amount") @db.Decimal(12, 2)

  /// Lifecycle status for the overall group/payment flow.
  status BookingGroupStatus @default(request)

  /// Request/response metadata mirrored from UI.
  requestedAt DateTime  @default(now()) @map("requested_at")
  respondedAt DateTime? @map("responded_at")
  expiresAt   DateTime? @map("expires_at")

  specialRequest String? @map("special_request") @db.Text
  internalNotes  String? @map("internal_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Parent    @relation(fields: [parentId], references: [id], onDelete: Restrict)
  session  Session   @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  camp     Camp      @relation(fields: [campId], references: [id], onDelete: Restrict)
  provider Provider  @relation(fields: [providerId], references: [id], onDelete: Restrict)
  bookings Booking[]

  @@index([parentId])
  @@index([sessionId])
  @@index([campId])
  @@index([providerId])
  @@index([createdAt])
  @@index([status])
  @@map("booking_groups")
}

model Session {
  id     String @id @default(uuid())
  campId String @map("camp_id")

  // Basic Fields
  name      String   @db.VarChar(60)
  startDate DateTime @map("start_date") // Actual session start
  endDate   DateTime @map("end_date") // Actual session end

  // Session Type (only for day camps)
  sessionDayType SessionDayType? @map("session_day_type") // 'full_day' | 'half_day'
  arrivalTime    String?         @map("arrival_time") // HH:MM format, only for half_day
  departureTime  String?         @map("departure_time") // HH:MM format, only for half_day

  // Pricing
  pricingType    PricingType @default(single) @map("pricing_type") // 'single' | 'age_group'
  price          Decimal?    @db.Decimal(10, 2) // For single pricing
  ageGroupPrices Json?       @map("age_group_prices") // [{age_group_id: string, price: number}]

  // Availability
  availabilityType AvailabilityType @default(single) @map("availability_type") // 'single' | 'age_group'
  totalSpots       Int?             @map("total_spots") // For single availability
  ageGroupSpots    Json?            @map("age_group_spots") // [{age_group_id: string, spots: number}]

  // Discounts
  discounts Json? // Array of applied discounts (global + session-specific)

  // Status
  status SessionStatus @default(draft) // 'draft' | 'published'

  // Metadata
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  camp           Camp            @relation(fields: [campId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  bookingGroups  BookingGroup[]
  supportTickets SupportTicket[]

  @@index([campId])
  @@index([status])
  @@index([sortOrder])
  @@map("sessions")
}

/// One booking = one child. Siblings share a booking_group_id; parent pays once per group.
/// Lifecycle: request → accepted|declined|expired → deposit_paid → fully_paid → at_camp → completed; any → cancelled.
model Booking {
  id             String @id @default(uuid())
  bookingNumber  String @unique @map("booking_number") @db.VarChar(36)
  bookingGroupId String @map("booking_group_id")
  sessionId      String @map("session_id")
  campId         String @map("camp_id")
  providerId     String @map("provider_id")
  parentId       String @map("parent_id")
  childId        String @map("child_id")

  // Dates & price
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  duration       Json? // Flexible sessions: {weeks: 2, days: 3}
  /// Base price for this child before discounts.
  basePrice      Decimal  @map("base_price") @db.Decimal(10, 2)
  /// Total discount amount applied to this child.
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(10, 2)
  /// Line total for this child (after discounts); payment is tracked at BookingGroup level.
  totalPrice     Decimal  @map("price") @db.Decimal(10, 2)

  // Provider response (when status is request)
  /// 72-hour deadline for provider to accept/decline; auto-expire if no response.
  requestExpiresAt DateTime? @map("request_expires_at")
  respondedAt      DateTime? @map("responded_at")
  /// Private note from provider when accepting or declining.
  providerNote     String?   @map("provider_note") @db.Text

  /// Selected add-ons for this specific child booking.
  addOns    BookingCampAddOn[]
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  bookingGroup   BookingGroup    @relation(fields: [bookingGroupId], references: [id], onDelete: Restrict)
  session        Session         @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  camp           Camp            @relation(fields: [campId], references: [id], onDelete: Restrict)
  provider       Provider        @relation(fields: [providerId], references: [id], onDelete: Restrict)
  parent         Parent          @relation(fields: [parentId], references: [id], onDelete: Restrict)
  child          Children        @relation(fields: [childId], references: [id], onDelete: Restrict)
  supportTickets SupportTicket[]

  @@index([bookingGroupId])
  @@index([sessionId])
  @@index([campId])
  @@index([providerId])
  @@index([parentId])
  @@index([childId])
  @@index([requestExpiresAt])
  @@map("bookings")
}

/// Booking lifecycle: request → provider response → payment → at camp → completed; any → cancelled.
enum BookingGroupStatus {
  draft // Parent draft before request submission
  request // Awaiting provider response
  accepted // Provider accepted
  declined // Provider declined
  expired // No provider response by request_expires_at
  deposit_paid // Deposit received
  fully_paid // Balance paid
  at_camp // Child currently at camp
  completed // Camp finished
  cancelled // Cancelled from any prior status
}


// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// User Management & Authentication
// ============================================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  userAccounts         UserAccount[]
  roles                UserRole[]
  parentProfile        Parent?
  ownedProvider        Provider?
  approvedProviders    Provider[]             @relation("ApprovedProviders")
  reviewedApplications Provider[]             @relation("ReviewedApplications")
  emailVerifications   EmailVerification[]
  passwordResets       PasswordReset[]
  reviewedDocuments    VerificationDocument[] @relation("ReviewedDocuments")

  @@map("users")
}

model UserAccount {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  type                  String
  authProvider          String   @map("auth_provider")
  authProviderAccountId String   @map("auth_provider_account_id")
  refreshToken          String?  @map("refresh_token") @db.Text
  accessToken           String?  @map("access_token") @db.Text
  expiresAt             Int?     @map("expires_at")
  tokenType             String?  @map("token_type")
  scope                 String?
  idToken               String?  @map("id_token") @db.Text
  sessionState          String?  @map("session_state")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([authProvider, authProviderAccountId])
  @@index([userId])
  @@map("user_accounts")
}

// ============================================
// RBAC (Role-Based Access Control)
// ============================================

model Role {
  id           String   @id @default(uuid())
  name         String
  isSystemRole Boolean  @default(false) @map("is_system_role")
  providerId   String?  @map("provider_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  provider    Provider?        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([name, providerId])
  @@index([providerId])
  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Permission {
  id        String   @id
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ============================================
// Provider (Organization)
// ============================================

model Provider {
  id         String   @id @default(uuid())
  name       String
  ownerId    String   @unique @map("owner_id")
  address    String?
  city       String?
  state      String?
  postalCode String?  @map("postal_code")
  country    String?
  phone      String?
  email      String?
  website    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Contact & Account (Step 2)
  contactFirstName   String?   @map("contact_first_name")
  contactLastName    String?   @map("contact_last_name")
  contactRole        String?   @map("contact_role")
  contactPhone       String?   @map("contact_phone")
  contactEmail       String?   @map("contact_email")
  phoneVerified      Boolean   @default(false) @map("phone_verified")
  phoneVerifiedAt    DateTime? @map("phone_verified_at")
  legalCompanyName   String?   @map("legal_company_name")
  legalStreetAddress String?   @map("legal_street_address")
  legalAptSuite      String?   @map("legal_apt_suite")
  legalCity          String?   @map("legal_city")
  legalStateProvince String?   @map("legal_state_province")
  legalPostalCode    String?   @map("legal_postal_code")
  legalCountry       String?   @map("legal_country")
  yearFounded        Int?      @map("year_founded")

  // Camp Details (Step 3)
  description String? @db.Text
  campType    String? @map("camp_type")
  minAge      Int?    @map("min_age")
  maxAge      Int?    @map("max_age")

  // Approval Status
  trustScore          Int?           @map("trust_score")
  trustScoreBreakdown Json?          @map("trust_score_breakdown")
  approvalStatus      ApprovalStatus @default(pending) @map("approval_status")
  approvalDecisionAt  DateTime?      @map("approval_decision_at")
  approvedByAdminId   String?        @map("approved_by_admin_id")
  rejectionReason     String?        @map("rejection_reason") @db.Text
  rejectionCategory   String?        @map("rejection_category")

  // Application Review
  applicationSubmittedAt DateTime? @map("application_submitted_at")
  applicationReviewedAt  DateTime? @map("application_reviewed_at")
  applicationReviewedBy  String?   @map("application_reviewed_by")

  // Onboarding Progress
  onboardingStartedAt   DateTime? @map("onboarding_started_at")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  onboardingCurrentStep Int       @default(1) @map("onboarding_current_step")
  lastLoginAt           DateTime? @map("last_login_at")

  // Terms & Conditions Acceptance
  termsAcceptedAt             DateTime? @map("terms_accepted_at")
  termsVersion                String?   @map("terms_version")
  providerAgreementAcceptedAt DateTime? @map("provider_agreement_accepted_at")
  providerAgreementVersion    String?   @map("provider_agreement_version")

  // Relations
  owner                 User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  approvedByAdmin       User?                  @relation("ApprovedProviders", fields: [approvedByAdminId], references: [id])
  reviewedByUser        User?                  @relation("ReviewedApplications", fields: [applicationReviewedBy], references: [id])
  roles                 Role[]
  googleBusinessProfile GoogleBusinessProfile?
  settings              ProviderSettings?
  verificationDocuments VerificationDocument[]
  camps                 Camp[]
  addOns                AddOn[]

  @@index([ownerId])
  @@index([approvalStatus])
  @@index([approvedByAdminId])
  @@index([applicationReviewedBy])
  @@map("providers")
}

// ============================================
// Parent Profile
// ============================================

model Parent {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  phone      String?
  address    String?
  city       String?
  state      String?
  postalCode String?  @map("postal_code")
  country    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  children Children[]
  bookings Booking[]

  @@index([userId])
  @@map("parents")
}

// ============================================
// Children
// ============================================

model Children {
  id          String    @id @default(uuid())

  // Personal Information
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  dateOfBirth DateTime? @map("date_of_birth")
  gender      String?
  nationality String?
  languages   String[]  @default([])

  // Academic Preferences
  currentGrade              String?   @map("current_grade")
  favoriteSubjects          String[]  @default([]) @map("favorite_subjects")
  learningStyle             String?   @map("learning_style")
  languagesOfInstruction    String[]  @default([]) @map("languages_of_instruction")
  interestedInBoarding      String?   @map("interested_in_boarding")

  // Extra-Curricular
  interests         String[]  @default([])
  preferredSchedule String?   @map("preferred_schedule")

  // Special Needs
  specialNeedsAreas        String[]  @default([]) @map("special_needs_areas")
  specialNeedsSupportNeeds String[]  @default([]) @map("special_needs_support_needs")
  specialNeedsNotes        String?   @map("special_needs_notes")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // The parent this child belongs to
  parentId String @map("parent_id")
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  // Relations
  bookings Booking[]

  @@index([parentId])
  @@map("children")
}

// ============================================
// Email Verification
// ============================================

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@map("email_verifications")
}

// ============================================
// Password Reset
// ============================================

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_resets")
}

// ============================================
// Provider Onboarding
// ============================================

model GoogleBusinessProfile {
  id         String @id @default(uuid())
  providerId String @unique @map("provider_id")

  // Google Places Data
  placeId          String @unique @map("place_id")
  businessName     String @map("business_name")
  formattedAddress String @map("formatted_address")

  // Address Components
  streetNumber String? @map("street_number")
  streetName   String? @map("street_name")
  city         String?
  state        String?
  postalCode   String? @map("postal_code")
  country      String?

  // Location
  lat Decimal @db.Decimal(10, 8)
  lng Decimal @db.Decimal(11, 8)

  // Business Info
  rating       Decimal? @db.Decimal(2, 1)
  reviewsCount Int?     @map("reviews_count")
  phone        String?
  website      String?

  // Additional Data
  photos  Json? // Array of photo references
  types   Json? // Array of business types
  dataRaw Json? @map("data_raw") // Full API response

  fetchedAt DateTime @default(now()) @map("fetched_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("google_business_profiles")
}

model ProviderSettings {
  id         String @id @default(uuid())
  providerId String @unique @map("provider_id")

  // Regional Settings
  currency String // ISO 4217 currency code
  timezone String // IANA timezone

  // Deposit Settings
  depositRequired    Boolean  @default(false) @map("deposit_required")
  depositType        String?  @map("deposit_type") // 'percentage' | 'fixed'
  depositPercentage  Int?     @map("deposit_percentage")
  depositFixedAmount Decimal? @map("deposit_fixed_amount") @db.Decimal(10, 2)

  // Cancellation Policy
  cancellationPolicy       String @default("moderate") @map("cancellation_policy") // 'flexible' | 'moderate' | 'strict' | 'custom'
  cancellationPolicyCustom Json?  @map("cancellation_policy_custom")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_settings")
}

model VerificationDocument {
  id            String  @id @default(uuid())
  providerId    String  @map("provider_id")
  documentType  String  @map("document_type") // 'business_registration' | 'insurance_certificate'
  fileUrl       String  @map("file_url")
  fileName      String? @map("file_name")
  fileSizeBytes Int?    @map("file_size_bytes")
  mimeType      String? @map("mime_type")

  // Review & Verification
  reviewStatus      DocumentReviewStatus @default(pending) @map("review_status")
  reviewedByAdminId String?              @map("reviewed_by_admin_id")
  reviewedAt        DateTime?            @map("reviewed_at")
  reviewChecklist   Json?                @map("review_checklist")
  reviewNotes       String?              @map("review_notes") @db.Text
  rejectionReason   String?              @map("rejection_reason") @db.Text

  uploadedAt DateTime @default(now()) @map("uploaded_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  provider        Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?    @relation("ReviewedDocuments", fields: [reviewedByAdminId], references: [id])

  @@index([providerId])
  @@index([documentType])
  @@map("verification_documents")
}

// ============================================
// Camps Management
// ============================================

model Camp {
  id         String @id @default(uuid())
  providerId String @map("provider_id")

  // Basic Info (Step 1 - Wizard & Editor)
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(150)
  type        CampType
  description String   @db.Text

  // Location
  locationType    LocationType
  locationPlaceId String?      @map("location_place_id")
  locationName    String?      @map("location_name")
  locationAddress String?      @map("location_address") @db.Text
  locationLat     Decimal?     @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal?     @map("location_lng") @db.Decimal(11, 8)

  // Audience (Step 2 - Wizard & Editor)
  ageGroups Json // [{min: 6, max: 17}, ...]
  languages String[] // ['english', 'french', ...]
  gender    Gender

  // Programs (Step 3 - Wizard & Editor)
  activities String[] // ['sports', 'water', 'arts', ...]

  // Photos (Step 4 - Wizard, Editor has separate section)
  photos Json? // [{id, url, thumbnail, isPrimary}, ...]

  // Sessions (Step 5 - Wizard & Editor)
  sessionType SessionType? @map("session_type") // 'flexible' | 'fixed' - set once, cannot change after first session

  // Editor-only fields
  whatsIncluded           Json?   // {items: string[], customItems: string[]}
  scheduleType            String? // 'daily' | 'weekly' | null
  dailySchedule           Json?   // For daily schedule data
  weeklySchedule          Json?   // For weekly schedule data
  meals                   Json?   // {breakfast, lunch, dinner, snacks, dietary}
  sportsActivities        Json? // {selected: string[], details: {...}}
  languagePrograms        Json? // {selected: string[], details: {...}}
  artsAndCrafts           Json? // {selected: string[], details: {...}}
  adventureActivities     Json?
  waterActivities         Json?
  environmentalActivities Json?
  academics               Json?
  religionPrograms        Json?
  excursionsTrips         Json?
  campusFacilities        Json? // {facilities: string[], description}
  accommodation           Json? // {type, rooms, amenities}
  gettingThere            Json? // {directions, transportation}
  campFocus               Json? // {primaryFocus: {activityId, activityName, categoryId, categoryName, icon}, description, philosophy, learningApproach}

  // Publishing
  status      CampStatus @default(draft)
  publishedAt DateTime?  @map("published_at")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  provider   Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  campAddOns CampAddOn[]
  sessions   Session[]

  @@index([providerId])
  @@index([status])
  @@index([sessionType])
  @@index([slug])
  @@map("camps")
}

// ============================================
// Enums
// ============================================

enum ApprovalStatus {
  pending
  under_review
  info_requested
  approved
  rejected
  suspended
}

enum DocumentReviewStatus {
  pending
  approved
  rejected
  needs_reupload
}

enum CampType {
  day
  residential
}

enum LocationType {
  provider
  different
}

enum Gender {
  coed
  boys
  girls
}

enum CampStatus {
  draft
  published
  archived
}

enum SessionType {
  flexible
  fixed
}

// ============================================
// Sessions & Bookings
// ============================================

model Session {
  id     String      @id @default(uuid())
  campId String      @map("camp_id")
  type   SessionType

  // Common Fields
  name        String  @db.VarChar(100)
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")
  capacity    Int? // null = unlimited
  sortOrder   Int     @default(0) @map("sort_order")

  // Flexible Session Fields (only used when type = 'flexible')
  startDate     DateTime? @map("start_date") // Booking window start
  endDate       DateTime? @map("end_date") // Booking window end
  blackoutDates Json?     @map("blackout_dates") // [{start: '2026-07-04', end: '2026-07-04', reason: 'Holiday'}, ...]

  // Flexible Session Pricing & Configuration
  basePricePerDay        Decimal? @map("base_price_per_day") @db.Decimal(10, 2)
  requireConsecutiveDays Boolean? @default(false) @map("require_consecutive_days")
  minDaysLimit           Int?     @map("min_days_limit")
  maxDaysLimit           Int?     @map("max_days_limit")
  availableDaysOfWeek    Json?    @map("available_days_of_week") // [0,1,2,3,4,5,6]
  specificStartDays      Json?    @map("specific_start_days") // [0,1,2,3,4,5,6]
  discountTiers          Json?    @map("discount_tiers") // [{minDays: 7, maxDays: 13, discountPercent: 10}, ...]
  dayOfWeekPricing       Json?    @map("day_of_week_pricing") // [{dayOfWeek: 0, price: 100}, ...]
  ageRange               Json?    @map("age_range") // {min: 5, max: 12}
  unlimitedCapacity      Boolean? @default(false) @map("unlimited_capacity")
  boysCapacity           Int?     @map("boys_capacity")
  girlsCapacity          Int?     @map("girls_capacity")
  separateGenderCapacity Boolean? @default(false) @map("separate_gender_capacity")

  // Fixed Session Fields (only used when type = 'fixed')
  sessionStartDate DateTime? @map("session_start_date") // Actual session start
  sessionEndDate   DateTime? @map("session_end_date") // Actual session end
  price            Decimal?  @db.Decimal(10, 2)

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  camp     Camp      @relation(fields: [campId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([campId])
  @@index([type])
  @@index([isActive])
  @@index([sortOrder])
  @@map("sessions")
}

model Booking {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  campId    String @map("camp_id")

  // Parent & Child Info
  parentId String @map("parent_id")
  childId  String @map("child_id")

  // Booking Details
  startDate DateTime      @map("start_date") // When child starts attending
  endDate   DateTime      @map("end_date") // When child finishes
  duration  Json? // For flexible sessions: {weeks: 2, days: 3}
  price     Decimal       @db.Decimal(10, 2)
  status    BookingStatus @default(pending)

  // Payment
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  depositAmount Decimal?      @map("deposit_amount") @db.Decimal(10, 2)

  // Add-ons
  addOns Json? @map("add_ons") // [{addOnId, quantity, price}, ...]

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  session Session  @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  parent  Parent   @relation(fields: [parentId], references: [id], onDelete: Restrict)
  child   Children @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([sessionId])
  @@index([campId])
  @@index([parentId])
  @@index([childId])
  @@index([status])
  @@index([paymentStatus])
  @@map("bookings")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

enum PaymentStatus {
  pending
  partial
  paid
  refunded
}

// ============================================
// Add-ons
// ============================================

model AddOn {
  id         String @id @default(uuid())
  providerId String @map("provider_id")

  // Basic Info
  name        String    @db.VarChar(120)
  description String?   @db.Text
  icon        String?   @db.VarChar(10) // Emoji
  type        AddOnType

  // Pricing
  price       Decimal     @db.Decimal(10, 2)
  currency    String      @default("CHF") @db.VarChar(3)
  pricingUnit PricingUnit

  // Quantity Limits
  maxQuantity  Int?    @map("max_quantity")
  quantityUnit String? @map("quantity_unit") @db.VarChar(50) // e.g., "per week"

  // Age Restrictions
  minAge Int? @map("min_age")
  maxAge Int? @map("max_age")

  // Status & Ordering
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  provider   Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  campAddOns CampAddOn[]

  @@index([providerId])
  @@index([type])
  @@index([isActive])
  @@index([sortOrder])
  @@map("add_ons")
}

// Junction table for many-to-many relationship between Camps and AddOns
model CampAddOn {
  campId    String  @map("camp_id")
  addOnId   String  @map("add_on_id")
  isEnabled Boolean @default(true) @map("is_enabled") // Toggle on/off for specific camp
  sortOrder Int     @default(0) @map("sort_order") // Camp-specific ordering

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  camp  Camp  @relation(fields: [campId], references: [id], onDelete: Cascade)
  addOn AddOn @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([campId, addOnId])
  @@index([campId])
  @@index([addOnId])
  @@map("camp_add_ons")
}

enum AddOnType {
  activity
  service
  equipment
  language
}

enum PricingUnit {
  per_child
  per_hour
  per_session
  per_week
  per_bag
  one_time
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// User Management & Authentication
// ============================================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  userAccounts         UserAccount[]
  roles                UserRole[]
  parentProfile        Parent?
  ownedProvider        Provider?
  approvedProviders    Provider[]             @relation("ApprovedProviders")
  reviewedApplications Provider[]             @relation("ReviewedApplications")
  emailVerifications   EmailVerification[]
  passwordResets       PasswordReset[]
  reviewedDocuments    VerificationDocument[] @relation("ReviewedDocuments")

  // Messaging Relations
  conversationParticipants   ConversationParticipant[]
  sentMessages               Message[]
  messageReadReceipts        MessageReadReceipt[]
  uploadedAttachments        MessageAttachment[]
  presence                   UserPresence?
  messageDeliveryReceipts    MessageDeliveryReceipt[]
  messageReactions           MessageReaction[]
  messageEdits               MessageEditHistory[]          @relation("MessageEditor")
  messageMentions            MessageMention[]
  messageBookmarks           MessageBookmark[]
  reportedMessages           MessageReport[]               @relation("ReportedMessages")
  reviewedReports            MessageReport[]               @relation("ReviewedReports")
  createdLabels              ConversationLabel[]
  assignedLabels             ConversationLabelAssignment[]
  assignedConversations      Conversation[]                @relation("AssignedConversations")
  conversationsAssigned      Conversation[]                @relation("AssignedByUser")
  statusChangedConversations Conversation[]                @relation("StatusChangedByUser")

  @@map("users")
}

model UserAccount {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  type                  String
  authProvider          String   @map("auth_provider")
  authProviderAccountId String   @map("auth_provider_account_id")
  refreshToken          String?  @map("refresh_token") @db.Text
  accessToken           String?  @map("access_token") @db.Text
  expiresAt             Int?     @map("expires_at")
  tokenType             String?  @map("token_type")
  scope                 String?
  idToken               String?  @map("id_token") @db.Text
  sessionState          String?  @map("session_state")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([authProvider, authProviderAccountId])
  @@index([userId])
  @@map("user_accounts")
}

// ============================================
// RBAC (Role-Based Access Control)
// ============================================

model Role {
  id           String   @id @default(uuid())
  name         String
  isSystemRole Boolean  @default(false) @map("is_system_role")
  providerId   String?  @map("provider_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  provider    Provider?        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([name, providerId])
  @@index([providerId])
  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Permission {
  id        String   @id
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ============================================
// Provider (Organization)
// ============================================

model Provider {
  id                 String   @id @default(uuid())
  ownerId            String   @unique @map("owner_id")
  legalCompanyName   String?  @map("legal_company_name")
  legalStreetAddress String?  @map("legal_street_address")
  legalAptSuite      String?  @map("legal_apt_suite")
  legalCity          String?  @map("legal_city")
  legalStateProvince String?  @map("legal_state_province")
  legalPostalCode    String?  @map("legal_postal_code")
  legalCountry       String?  @map("legal_country")
  yearFounded        Int?     @map("year_founded")
  phone              String?
  email              String?
  website            String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Contact & Account (Step 2)
  contactFirstName String? @map("contact_first_name")
  contactLastName  String? @map("contact_last_name")
  contactRole      String? @map("contact_role")
  contactPhone     String? @map("contact_phone")
  contactEmail     String? @map("contact_email")

  // Camp Details (Step 3)
  description String? @db.Text
  campType    String? @map("camp_type")

  // Approval Status
  trustScore          Int?           @map("trust_score")
  trustScoreBreakdown Json?          @map("trust_score_breakdown")
  approvalStatus      ApprovalStatus @default(pending) @map("approval_status")
  approvalDecisionAt  DateTime?      @map("approval_decision_at")
  approvedByAdminId   String?        @map("approved_by_admin_id")
  rejectionReason     String?        @map("rejection_reason") @db.Text
  rejectionCategory   String?        @map("rejection_category")

  // Application Review
  applicationSubmittedAt DateTime? @map("application_submitted_at")
  applicationReviewedAt  DateTime? @map("application_reviewed_at")
  applicationReviewedBy  String?   @map("application_reviewed_by")

  // Onboarding Progress
  onboardingStartedAt   DateTime? @map("onboarding_started_at")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  onboardingCurrentStep Int       @default(1) @map("onboarding_current_step")
  lastLoginAt           DateTime? @map("last_login_at")

  // Terms & Conditions Acceptance
  termsAcceptedAt             DateTime? @map("terms_accepted_at")
  termsVersion                String?   @map("terms_version")
  providerAgreementAcceptedAt DateTime? @map("provider_agreement_accepted_at")
  providerAgreementVersion    String?   @map("provider_agreement_version")

  // Relations
  owner                 User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  approvedByAdmin       User?                  @relation("ApprovedProviders", fields: [approvedByAdminId], references: [id])
  reviewedByUser        User?                  @relation("ReviewedApplications", fields: [applicationReviewedBy], references: [id])
  roles                 Role[]
  googleBusinessProfile GoogleBusinessProfile?
  settings              ProviderSettings?
  verificationDocuments VerificationDocument[]
  camps                 Camp[]
  addOns                AddOn[]

  // Messaging Relations
  conversationParticipants ConversationParticipant[]

  @@index([ownerId])
  @@index([approvalStatus])
  @@index([approvedByAdminId])
  @@index([applicationReviewedBy])
  @@map("providers")
}

// ============================================
// Parent Profile
// ============================================

model Parent {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  phone      String?
  address    String?
  city       String?
  state      String?
  postalCode String?  @map("postal_code")
  country    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  children Children[]
  bookings Booking[]

  @@index([userId])
  @@map("parents")
}

// ============================================
// Children
// ============================================

model Children {
  id String @id @default(uuid())

  // Basic Information (30% weight)
  firstName     String    @map("first_name")
  lastName      String?   @map("last_name")
  nickname      String?
  dateOfBirth   DateTime? @map("date_of_birth")
  gender        String?
  photoUrl      String?   @map("photo_url")
  schoolYear    String?   @map("school_year")
  schoolCountry String?   @map("school_country")
  languages     String[]  @default([])

  // Medical Information (20% weight) - JSONB
  medicalInfo Json? @map("medical_info")

  // Emergency Contacts (25% weight) - JSONB array
  emergencyContacts Json @default("[]") @map("emergency_contacts")

  // Camp Preferences (15% weight) - JSONB
  campPreferences Json? @map("camp_preferences")

  // Profile Completion
  profileCompletion Int @default(0) @map("profile_completion")

  // Soft Delete
  archived Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // The parent this child belongs to
  parentId String @map("parent_id")
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  // Relations
  bookings Booking[]

  @@index([parentId])
  @@index([archived])
  @@map("children")
}

// ============================================
// Email Verification
// ============================================

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@map("email_verifications")
}

// ============================================
// Password Reset
// ============================================

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_resets")
}

// ============================================
// Provider Onboarding
// ============================================

model GoogleBusinessProfile {
  id         String @id @default(uuid())
  providerId String @unique @map("provider_id")

  // Google Places Data
  placeId          String @unique @map("place_id")
  businessName     String @map("business_name")
  formattedAddress String @map("formatted_address")

  // Address Components
  streetNumber String? @map("street_number")
  streetName   String? @map("street_name")
  city         String?
  state        String?
  postalCode   String? @map("postal_code")
  country      String?

  // Location
  lat Decimal @db.Decimal(10, 8)
  lng Decimal @db.Decimal(11, 8)

  // Business Info
  rating       Decimal? @db.Decimal(2, 1)
  reviewsCount Int?     @map("reviews_count")
  phone        String?
  website      String?

  // Additional Data
  photos  Json? // Array of photo references
  types   Json? // Array of business types
  dataRaw Json? @map("data_raw") // Full API response

  fetchedAt DateTime @default(now()) @map("fetched_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("google_business_profiles")
}

model ProviderSettings {
  id         String @id @default(uuid())
  providerId String @unique @map("provider_id")

  // Regional Settings
  currency String // ISO 4217 currency code
  timezone String // IANA timezone

  // Deposit Settings
  depositRequired    Boolean  @default(false) @map("deposit_required")
  depositType        String?  @map("deposit_type") // 'percentage' | 'fixed'
  depositPercentage  Int?     @map("deposit_percentage")
  depositFixedAmount Decimal? @map("deposit_fixed_amount") @db.Decimal(10, 2)

  // Cancellation Policy
  cancellationPolicy       String @default("moderate") @map("cancellation_policy") // 'flexible' | 'moderate' | 'strict' | 'custom'
  cancellationPolicyCustom Json?  @map("cancellation_policy_custom")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_settings")
}

model VerificationDocument {
  id            String  @id @default(uuid())
  providerId    String  @map("provider_id")
  documentType  String  @map("document_type") // Required: 'business_registration' | 'insurance_certificate' | Accreditations: 'aca' | 'icf' | 'bsa' | 'national_accreditation' | 'regional_accreditation' | 'other_accreditation' | Safety: 'risk_policy' | 'first_aid' | 'lifeguard' | 'background_check' | 'emergency_plan' | 'food_safety' | 'other_safety'
  customTitle   String? @map("custom_title") // For 'other_accreditation' and 'other_safety' types
  fileUrl       String  @map("file_url")
  fileName      String? @map("file_name")
  fileSizeBytes Int?    @map("file_size_bytes")
  mimeType      String? @map("mime_type")

  // Review & Verification
  reviewStatus      DocumentReviewStatus @default(pending) @map("review_status")
  reviewedByAdminId String?              @map("reviewed_by_admin_id")
  reviewedAt        DateTime?            @map("reviewed_at")
  reviewChecklist   Json?                @map("review_checklist")
  reviewNotes       String?              @map("review_notes") @db.Text
  rejectionReason   String?              @map("rejection_reason") @db.Text

  uploadedAt DateTime @default(now()) @map("uploaded_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  provider        Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?    @relation("ReviewedDocuments", fields: [reviewedByAdminId], references: [id])

  @@index([providerId])
  @@index([documentType])
  @@map("verification_documents")
}

// ============================================
// Camps Management
// ============================================

model Camp {
  id         String @id @default(uuid())
  providerId String @map("provider_id")

  // Basic Info (Step 1 - Wizard & Editor)
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(150)
  type        CampType
  description String   @db.Text

  // Location
  locationType    LocationType
  locationPlaceId String?      @map("location_place_id")
  locationName    String?      @map("location_name")
  locationAddress String?      @map("location_address") @db.Text
  locationLat     Decimal?     @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal?     @map("location_lng") @db.Decimal(11, 8)

  // Audience (Step 2 - Wizard & Editor)
  ageGroups Json // [{min: 6, max: 17}, ...]
  languages String[] // ['english', 'french', ...]
  gender    Gender

  // Programs (Step 3 - Wizard & Editor)
  activities String[] // ['sports', 'water', 'arts', ...]

  // Photos (Step 4 - Wizard, Editor has separate section)
  photos Json? // [{id, url, thumbnail, isPrimary}, ...]

  // Editor-only fields
  whatsIncluded           Json? // {items: string[], customItems: string[]}
  scheduleType            String? // 'daily' | 'weekly' | null
  dailySchedule           Json? // For daily schedule data
  weeklySchedule          Json? // For weekly schedule data
  meals                   Json? // {breakfast, lunch, dinner, snacks, dietary}
  sportsActivities        Json? // {selected: string[], details: {...}}
  languagePrograms        Json? // {selected: string[], details: {...}}
  artsAndCrafts           Json? // {selected: string[], details: {...}}
  adventureActivities     Json?
  waterActivities         Json?
  environmentalActivities Json?
  academics               Json?
  religionPrograms        Json?
  excursionsTrips         Json?
  campusFacilities        Json? // {facilities: string[], description}
  accommodation           Json? // {type, rooms, amenities}
  gettingThere            Json? // {directions, transportation}
  campFocus               Json? // {primaryFocus: {activityId, activityName, categoryId, categoryName, icon}, description, philosophy, learningApproach}

  // Publishing
  status      CampStatus @default(draft)
  publishedAt DateTime?  @map("published_at")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  provider   Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  campAddOns CampAddOn[]
  sessions   Session[]

  @@index([providerId])
  @@index([status])
  @@index([slug])
  @@map("camps")
}

// ============================================
// Enums
// ============================================

enum ApprovalStatus {
  pending
  under_review
  info_requested
  approved
  rejected
  suspended
}

enum DocumentReviewStatus {
  pending
  approved
  rejected
  needs_reupload
}

enum CampType {
  day
  residential
}

enum LocationType {
  provider
  different
}

enum Gender {
  coed
  boys
  girls
}

enum CampStatus {
  draft
  published
  archived
}

enum SessionDayType {
  full_day
  half_day
}

enum PricingType {
  single
  age_group
}

enum AvailabilityType {
  single
  age_group
}

enum SessionStatus {
  draft
  published
}

// ============================================
// Sessions & Bookings
// ============================================

model Session {
  id     String @id @default(uuid())
  campId String @map("camp_id")

  // Basic Fields
  name      String   @db.VarChar(60)
  startDate DateTime @map("start_date") // Actual session start
  endDate   DateTime @map("end_date") // Actual session end

  // Session Type (only for day camps)
  sessionDayType SessionDayType? @map("session_day_type") // 'full_day' | 'half_day'
  arrivalTime    String?         @map("arrival_time") // HH:MM format, only for half_day
  departureTime  String?         @map("departure_time") // HH:MM format, only for half_day

  // Pricing
  pricingType    PricingType @default(single) @map("pricing_type") // 'single' | 'age_group'
  price          Decimal?    @db.Decimal(10, 2) // For single pricing
  ageGroupPrices Json?       @map("age_group_prices") // [{age_group_id: string, price: number}]

  // Availability
  availabilityType AvailabilityType @default(single) @map("availability_type") // 'single' | 'age_group'
  totalSpots       Int?             @map("total_spots") // For single availability
  ageGroupSpots    Json?            @map("age_group_spots") // [{age_group_id: string, spots: number}]

  // Status
  status SessionStatus @default(draft) // 'draft' | 'published'

  // Metadata
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  camp     Camp      @relation(fields: [campId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([campId])
  @@index([status])
  @@index([sortOrder])
  @@map("sessions")
}

model Booking {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  campId    String @map("camp_id")

  // Parent & Child Info
  parentId String @map("parent_id")
  childId  String @map("child_id")

  // Booking Details
  startDate DateTime      @map("start_date") // When child starts attending
  endDate   DateTime      @map("end_date") // When child finishes
  duration  Json? // For flexible sessions: {weeks: 2, days: 3}
  price     Decimal       @db.Decimal(10, 2)
  status    BookingStatus @default(pending)

  // Payment
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  depositAmount Decimal?      @map("deposit_amount") @db.Decimal(10, 2)

  // Add-ons
  addOns Json? @map("add_ons") // [{addOnId, quantity, price}, ...]

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  session Session  @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  parent  Parent   @relation(fields: [parentId], references: [id], onDelete: Restrict)
  child   Children @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([sessionId])
  @@index([campId])
  @@index([parentId])
  @@index([childId])
  @@index([status])
  @@index([paymentStatus])
  @@map("bookings")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

enum PaymentStatus {
  pending
  partial
  paid
  refunded
}

// ============================================
// Add-ons
// ============================================

model AddOn {
  id         String @id @default(uuid())
  providerId String @map("provider_id")

  // Basic Info
  name        String    @db.VarChar(120)
  description String?   @db.Text
  icon        String?   @db.VarChar(10) // Emoji
  type        AddOnType

  // Pricing
  price       Decimal     @db.Decimal(10, 2)
  currency    String      @default("CHF") @db.VarChar(3)
  pricingUnit PricingUnit

  // Quantity Limits
  maxQuantity  Int?    @map("max_quantity")
  quantityUnit String? @map("quantity_unit") @db.VarChar(50) // e.g., "per week"

  // Age Restrictions
  minAge Int? @map("min_age")
  maxAge Int? @map("max_age")

  // Status & Ordering
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  provider   Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  campAddOns CampAddOn[]

  @@index([providerId])
  @@index([type])
  @@index([isActive])
  @@index([sortOrder])
  @@map("add_ons")
}

// Junction table for many-to-many relationship between Camps and AddOns
model CampAddOn {
  campId    String  @map("camp_id")
  addOnId   String  @map("add_on_id")
  isEnabled Boolean @default(true) @map("is_enabled") // Toggle on/off for specific camp
  sortOrder Int     @default(0) @map("sort_order") // Camp-specific ordering

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  camp  Camp  @relation(fields: [campId], references: [id], onDelete: Cascade)
  addOn AddOn @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([campId, addOnId])
  @@index([campId])
  @@index([addOnId])
  @@map("camp_add_ons")
}

enum AddOnType {
  activity
  service
  equipment
  language
}

enum PricingUnit {
  per_child
  per_hour
  per_session
  per_week
  per_bag
  one_time
}

// ============================================
// Messaging System Models
// ============================================

model Conversation {
  id            String           @id @default(uuid())
  type          ConversationType
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  lastMessageId String?          @unique @map("last_message_id")

  // Context & Metadata (GAP 5)
  subject     String?      @db.VarChar(255)
  contextType ContextType? @map("context_type")
  contextId   String?      @map("context_id")
  metadata    Json?

  // Assignment (GAP 12)
  assignedToId String?   @map("assigned_to_id")
  assignedAt   DateTime? @map("assigned_at")
  assignedBy   String?   @map("assigned_by")

  // Status tracking (GAP 13)
  status              ConversationStatus @default(OPEN)
  openedAt            DateTime           @default(now()) @map("opened_at")
  statusChangedAt     DateTime?          @map("status_changed_at")
  statusChangedByUser String?            @map("status_changed_by")

  // Cached metrics (GAP 28)
  messageCount     Int      @default(0) @map("message_count")
  participantCount Int      @default(0) @map("participant_count")
  avgResponseTime  Int?     @map("avg_response_time") // seconds
  lastActivityAt   DateTime @default(now()) @map("last_activity_at")

  // Relations
  participants       ConversationParticipant[]
  messages           Message[]
  lastMessage        Message?                      @relation("LastMessage", fields: [lastMessageId], references: [id])
  labels             ConversationLabelAssignment[]
  assignedTo         User?                         @relation("AssignedConversations", fields: [assignedToId], references: [id], onDelete: SetNull)
  assigner           User?                         @relation("AssignedByUser", fields: [assignedBy], references: [id])
  statusChangedByRel User?                         @relation("StatusChangedByUser", fields: [statusChangedByUser], references: [id])

  @@index([type])
  @@index([updatedAt])
  @@index([contextType, contextId])
  @@index([assignedToId])
  @@index([assignedAt])
  @@index([status, updatedAt])
  @@index([lastActivityAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String  @id @default(uuid())
  conversationId String  @map("conversation_id")
  userId         String  @map("user_id")
  providerId     String? @map("provider_id") // For provider participants

  // Participant-specific settings
  pinned     Boolean   @default(false)
  pinnedAt   DateTime? @map("pinned_at")
  starred    Boolean   @default(false)
  muted      Boolean   @default(false)
  archived   Boolean   @default(false)
  archivedAt DateTime? @map("archived_at")

  // Read tracking
  lastReadAt  DateTime? @map("last_read_at")
  unreadCount Int       @default(0) @map("unread_count")

  // Auto-response settings (GAP 17)
  autoResponseEnabled Boolean   @default(false) @map("auto_response_enabled")
  autoResponseMessage String?   @map("auto_response_message") @db.Text
  autoResponseUntil   DateTime? @map("auto_response_until")
  businessHoursOnly   Boolean   @default(false) @map("business_hours_only")

  // Rate limiting (GAP 26)
  messageCount24h Int       @default(0) @map("message_count_24h")
  lastMessageAt   DateTime? @map("last_message_at")
  isRateLimited   Boolean   @default(false) @map("is_rate_limited")
  rateLimitUntil  DateTime? @map("rate_limit_until")

  // Metadata
  joinedAt DateTime  @default(now()) @map("joined_at")
  leftAt   DateTime? @map("left_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     Provider?    @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([providerId])
  @@index([conversationId, lastReadAt])
  @@index([isRateLimited])
  @@map("conversation_participants")
}

model Message {
  id             String     @id @default(uuid())
  conversationId String     @map("conversation_id")
  senderId       String     @map("sender_id")
  senderType     SenderType @map("sender_type")

  // Message content
  content     String      @db.Text
  contentType ContentType @default(TEXT) @map("content_type")

  // Attachments
  attachments Json? // Array of {id, url, type, size, name}

  // Message metadata
  type     MessageType @default(REGULAR)
  metadata Json? // For transfer requests, system messages, etc.

  // Reply/Threading support (GAP 1)
  replyToId String? @map("reply_to_id")

  // Forwarding support (GAP 9)
  forwardedFromId String? @map("forwarded_from_id")
  forwardCount    Int     @default(0) @map("forward_count")

  // Priority & Pinning (GAP 11)
  isPinned Boolean          @default(false) @map("is_pinned")
  pinnedAt DateTime?        @map("pinned_at")
  pinnedBy String?          @map("pinned_by")
  priority MessagePriority? @default(NORMAL)

  // Scheduling support (GAP 18)
  scheduledFor DateTime? @map("scheduled_for")
  scheduledBy  String?   @map("scheduled_by")
  isScheduled  Boolean   @default(false) @map("is_scheduled")

  // Status tracking
  status      MessageStatus @default(SENT)
  deliveredAt DateTime?     @map("delivered_at")
  readAt      DateTime?     @map("read_at")

  // Performance tracking (GAP 27)
  sentAt            DateTime @default(now()) @map("sent_at")
  deliveryLatencyMs Int?     @map("delivery_latency_ms")

  // Edit/Delete tracking (GAP 7 - Enhanced)
  editedAt     DateTime?     @map("edited_at")
  deletedAt    DateTime?     @map("deleted_at")
  deletedBy    String?       @map("deleted_by")
  isDeleted    Boolean       @default(false) @map("is_deleted")
  deletionType DeletionType? @map("deletion_type")

  // Full-text search support (GAP 6)
  searchVector Unsupported("tsvector")? @map("search_vector")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  conversation     Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender           User                     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  lastMessageFor   Conversation?            @relation("LastMessage")
  readReceipts     MessageReadReceipt[]
  deliveryReceipts MessageDeliveryReceipt[] // GAP 3
  reactions        MessageReaction[] // GAP 4
  editHistory      MessageEditHistory[] // GAP 8
  mentions         MessageMention[] // GAP 14
  bookmarks        MessageBookmark[] // GAP 15
  reports          MessageReport[] // GAP 25
  replyTo          Message?                 @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies          Message[]                @relation("MessageReplies")
  forwardedFrom    Message?                 @relation("MessageForwards", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwards         Message[]                @relation("MessageForwards")

  @@index([conversationId, createdAt])
  @@index([conversationId, createdAt(sort: Desc), id]) // GAP 2 - Cursor pagination
  @@index([senderId])
  @@index([status])
  @@index([createdAt])
  @@index([replyToId])
  @@index([forwardedFromId])
  @@index([conversationId, isPinned, createdAt])
  @@index([scheduledFor])
  @@index([isScheduled, scheduledFor])
  @@index([isDeleted, conversationId, createdAt])
  @@index([sentAt])
  @@index([searchVector], type: Gin) // GAP 6 - Full-text search
  @@map("messages")
}

model MessageReadReceipt {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@map("message_read_receipts")
}

// GAP 3: Message Delivery Tracking
model MessageDeliveryReceipt {
  id          String   @id @default(uuid())
  messageId   String   @map("message_id")
  userId      String   @map("user_id")
  deliveredAt DateTime @default(now()) @map("delivered_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@index([deliveredAt])
  @@map("message_delivery_receipts")
}

// GAP 4: Message Reactions
model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String   @db.VarChar(10) // Unicode emoji
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
  @@map("message_reactions")
}

// GAP 8: Message Edit History
model MessageEditHistory {
  id              String   @id @default(uuid())
  messageId       String   @map("message_id")
  previousContent String   @db.Text
  editedBy        String   @map("edited_by")
  editedAt        DateTime @default(now()) @map("edited_at")
  editReason      String?  @db.Text

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  editor  User    @relation("MessageEditor", fields: [editedBy], references: [id])

  @@index([messageId, editedAt])
  @@map("message_edit_history")
}

// GAP 14: Message Mentions
model MessageMention {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, createdAt])
  @@map("message_mentions")
}

// GAP 15: Message Bookmarks
model MessageBookmark {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, createdAt])
  @@map("message_bookmarks")
}

// GAP 25: Abuse Reporting
model MessageReport {
  id          String       @id @default(uuid())
  messageId   String       @map("message_id")
  reportedBy  String       @map("reported_by")
  reason      ReportReason
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  reviewedBy  String?      @map("reviewed_by")
  reviewedAt  DateTime?    @map("reviewed_at")
  resolution  String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")

  // Relations
  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter User    @relation("ReportedMessages", fields: [reportedBy], references: [id])
  reviewer User?   @relation("ReviewedReports", fields: [reviewedBy], references: [id])

  @@index([messageId])
  @@index([reportedBy])
  @@index([status])
  @@map("message_reports")
}

model MessageAttachment {
  id        String @id @default(uuid())
  messageId String @map("message_id")

  // File metadata
  fileName String   @map("file_name")
  fileSize Int      @map("file_size") // bytes
  mimeType String   @map("mime_type")
  fileType FileType @map("file_type")

  // Storage
  storageUrl   String  @map("storage_url") // Azure Blob Storage URL
  cdnUrl       String? @map("cdn_url") // CDN URL for fast delivery
  thumbnailUrl String? @map("thumbnail_url") // For images/videos

  // Metadata
  uploadedBy String   @map("uploaded_by")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  // Relations
  uploader User @relation(fields: [uploadedBy], references: [id])

  @@index([messageId])
  @@index([uploadedBy])
  @@map("message_attachments")
}

model TypingIndicator {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  startedAt      DateTime @default(now()) @map("started_at")
  expiresAt      DateTime @map("expires_at")

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([expiresAt])
  @@map("typing_indicators")
}

model UserPresence {
  userId     String         @id @map("user_id")
  status     PresenceStatus
  lastSeenAt DateTime       @default(now()) @map("last_seen_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lastSeenAt])
  @@map("user_presence")
}

// GAP 10: Conversation Labels
model ConversationLabel {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(50)
  color     String?  @db.VarChar(7) // Hex color code
  icon      String?  @db.VarChar(10) // Emoji
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  creator       User                          @relation(fields: [createdBy], references: [id])
  conversations ConversationLabelAssignment[]

  @@unique([name])
  @@map("conversation_labels")
}

model ConversationLabelAssignment {
  conversationId String   @map("conversation_id")
  labelId        String   @map("label_id")
  assignedBy     String   @map("assigned_by")
  assignedAt     DateTime @default(now()) @map("assigned_at")

  // Relations
  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label        ConversationLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  assigner     User              @relation(fields: [assignedBy], references: [id])

  @@id([conversationId, labelId])
  @@index([conversationId])
  @@index([labelId])
  @@map("conversation_label_assignments")
}

// ============================================
// Messaging System Enums
// ============================================

enum ConversationType {
  USER_PROVIDER // Parent/User ↔ Camp Provider
  USER_SUPERADMIN // Parent/User ↔ Platform Support
  PROVIDER_SUPERADMIN // Provider ↔ Platform Support (future)
}

enum SenderType {
  USER
  PROVIDER
  SUPERADMIN
  CHATBOT
  SYSTEM
}

enum ContentType {
  TEXT
  IMAGE
  FILE
  VIDEO
  AUDIO
}

enum MessageType {
  REGULAR
  TRANSFER_REQUEST
  TRANSFER_SUMMARY
  SYSTEM_NOTIFICATION
  CHATBOT_RESPONSE
}

enum MessageStatus {
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum FileType {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  OTHER
}

enum PresenceStatus {
  ONLINE
  AWAY
  OFFLINE
}

// GAP 5: Context Type
enum ContextType {
  BOOKING
  CAMP
  PROVIDER
  GENERAL
}

// GAP 7: Deletion Type
enum DeletionType {
  USER_DELETED // User deleted their own message
  ADMIN_DELETED // Admin/moderator deleted
  AUTO_DELETED // Auto-deleted (retention policy)
  GDPR_DELETED // GDPR right to be forgotten
}

// GAP 11: Message Priority
enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// GAP 13: Conversation Status
enum ConversationStatus {
  OPEN // Active conversation
  PENDING // Waiting for user response
  RESOLVED // Issue resolved, awaiting confirmation
  CLOSED // Conversation closed
  ARCHIVED // Archived for reference
}

// GAP 25: Report Reason
enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  SCAM
  IMPERSONATION
  OTHER
}

// GAP 25: Report Status
enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}
